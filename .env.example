# --- Admin (SSR) ---
# Password to unlock /admin. Set on Vercel dashboard (Project → Settings → Env).
ADMIN_PASSWORD=change-me-in-production
# Session cookie secret — 32+ random chars recommended.
ADMIN_COOKIE_SECRET=change-me-use-a-long-random-string

# --- Newsletter (Brevo) ---
# Create a list on brevo.com, paste the API key + list id here.
BREVO_API_KEY=
BREVO_LIST_ID=

# --- Contact / candidatures ---
# Email address that receives /service-client + /recrutement form submissions.
CONTACT_TO_EMAIL=contact@marchedemo.com
RESEND_API_KEY=

# --- Public URL (used for canonical + sitemap) ---
PUBLIC_SITE_URL=https://marchedemov2.vercel.app

# --- Supabase (backend promos/produits/médias) ---
# Project → Settings → API dans Supabase Studio.
SUPABASE_URL=https://your-project.supabase.co
# Anon (publishable) key — safe pour lecture publique via RLS.
SUPABASE_ANON_KEY=sb_publishable_...
# Service role (secret) key — SERVEUR UNIQUEMENT, bypasse RLS.
# À ajouter uniquement sur Vercel pour /admin et les API routes d'écriture.
SUPABASE_SERVICE_ROLE_KEY=
