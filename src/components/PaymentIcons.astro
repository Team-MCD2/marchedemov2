---
/**
 * PaymentIcons.astro — inline SVG brandmarks for payment methods.
 *
 * Each icon is a ~48x30 SVG with authentic brand colours, drawn from
 * simplified but recognisable official marks (wordmark or glyph).
 * These are fair-use "we accept X" merchant badges, standard for any
 * e-commerce footer or checkout.
 *
 * Sizes : viewBox 0 0 48 30. Render box : w-12 h-[30px] rounded.
 * Background : white card with subtle ring, consistent across brands.
 *
 * Usage :
 *   <PaymentIcons />
 */
---

<div class="flex flex-wrap items-center gap-2" role="list" aria-label="Moyens de paiement acceptés">
  {/* -------- Visa -------- */}
  <span role="listitem" class="payicon-wrap" title="Visa">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="Visa">
      <rect width="48" height="30" rx="4" fill="#fff"/>
      <path d="M20.1 19.8L21.7 10.2h2.6l-1.6 9.6h-2.6zm12.1-9.4c-.5-.2-1.3-.4-2.3-.4-2.5 0-4.3 1.3-4.3 3.2 0 1.4 1.3 2.2 2.3 2.6.9.4 1.3.7 1.3 1.1 0 .6-.7.8-1.4.8-1 0-1.5-.1-2.3-.5l-.3-.1-.3 2c.6.3 1.7.5 2.8.5 2.7 0 4.4-1.3 4.4-3.3 0-1.1-.7-2-2.1-2.6-.9-.4-1.4-.6-1.4-1.1 0-.4.4-.8 1.4-.8.8 0 1.4.2 1.9.4l.2.1.3-2zm6.1-.2l-2.1 9.6h-2.4s-1-4.5-1.3-5.9c-.1-.6-.1-.8-.2-1.2-.1.6-.3 1.8-.3 1.8L31 19.8h-2.6l-.7-9.6h2.5c.1 1.8.4 4 .5 5.2l.1.6c.2-1.2.5-2.3.7-3.3l.7-2.5h2.1zm-19.1 0l-2.5 6.5-.3-1.4c-.5-1.6-2-3.4-3.7-4.3l2.3 8.8h2.7l4-9.6h-2.5z" fill="#1A1F71"/>
      <path d="M13.4 10.2H9.3l-.1.3c3.2.8 5.3 2.7 6.2 5L14.4 11c-.2-.5-.6-.7-1-.8z" fill="#F9A51A"/>
    </svg>
  </span>

  {/* -------- Mastercard -------- */}
  <span role="listitem" class="payicon-wrap" title="Mastercard">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="Mastercard">
      <rect width="48" height="30" rx="4" fill="#fff"/>
      <circle cx="20" cy="15" r="7" fill="#EB001B"/>
      <circle cx="28" cy="15" r="7" fill="#F79E1B"/>
      <path d="M24 9.5a7 7 0 0 1 0 11 7 7 0 0 1 0-11z" fill="#FF5F00"/>
    </svg>
  </span>

  {/* -------- Maestro -------- */}
  <span role="listitem" class="payicon-wrap" title="Maestro">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="Maestro">
      <rect width="48" height="30" rx="4" fill="#fff"/>
      <circle cx="20" cy="15" r="7" fill="#0099DF"/>
      <circle cx="28" cy="15" r="7" fill="#EB001B"/>
      <path d="M24 9.5a7 7 0 0 1 0 11 7 7 0 0 1 0-11z" fill="#6C6BBD"/>
    </svg>
  </span>

  {/* -------- Carte Bancaire (CB) -------- */}
  <span role="listitem" class="payicon-wrap" title="Carte Bancaire">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="Carte Bancaire">
      <defs>
        <linearGradient id="cbgrad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#203D88"/>
          <stop offset="1" stop-color="#008F4C"/>
        </linearGradient>
      </defs>
      <rect width="48" height="30" rx="4" fill="url(#cbgrad)"/>
      <text x="24" y="20" font-family="Arial, Helvetica, sans-serif" font-weight="900" font-size="13" text-anchor="middle" fill="#fff" letter-spacing="-0.5">CB</text>
    </svg>
  </span>

  {/* -------- American Express -------- */}
  <span role="listitem" class="payicon-wrap" title="American Express">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="American Express">
      <rect width="48" height="30" rx="4" fill="#2E77BB"/>
      <text x="24" y="14" font-family="Arial, Helvetica, sans-serif" font-weight="900" font-size="5" text-anchor="middle" fill="#fff" letter-spacing="0.3">AMERICAN</text>
      <text x="24" y="22" font-family="Arial, Helvetica, sans-serif" font-weight="900" font-size="5" text-anchor="middle" fill="#fff" letter-spacing="0.3">EXPRESS</text>
    </svg>
  </span>

  {/* -------- Apple Pay -------- */}
  <span role="listitem" class="payicon-wrap" title="Apple Pay">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="Apple Pay">
      <rect width="48" height="30" rx="4" fill="#fff"/>
      <path d="M13.7 11c.4-.5.7-1.2.6-1.9-.6 0-1.3.4-1.7.9-.4.4-.7 1.2-.6 1.8.7.1 1.3-.3 1.7-.8zm.6.9c-.9-.1-1.7.5-2.2.5-.5 0-1.1-.5-1.9-.5-1 0-1.9.6-2.4 1.4-1 1.8-.3 4.4.7 5.8.5.7 1 1.5 1.8 1.5.7 0 1-.5 1.9-.5.9 0 1.1.5 1.9.5.8 0 1.3-.7 1.7-1.4.6-.8.8-1.6.8-1.7 0 0-1.5-.6-1.5-2.3 0-1.5 1.2-2.2 1.2-2.2-.7-1-1.7-1.1-2-1.1z" fill="#000"/>
      <text x="31" y="19.5" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="8" fill="#000">Pay</text>
    </svg>
  </span>

  {/* -------- Google Pay -------- */}
  <span role="listitem" class="payicon-wrap" title="Google Pay">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="Google Pay">
      <rect width="48" height="30" rx="4" fill="#fff"/>
      <path d="M15.1 15.2c0-.5 0-.9-.1-1.3h-4v2.5h2.3c-.1.5-.4 1-.9 1.3v1.1h1.4c.8-.8 1.3-1.9 1.3-3.2v-.4z" fill="#4285F4"/>
      <path d="M11 19.2c1.2 0 2.2-.4 2.9-1.1l-1.4-1.1c-.4.3-.9.4-1.5.4-1.1 0-2.1-.7-2.4-1.8h-1.5v1.1c.7 1.5 2.2 2.5 3.9 2.5z" fill="#34A853"/>
      <path d="M8.6 15.7c-.1-.3-.2-.6-.2-.9 0-.3.1-.6.2-.9v-1.1H7.1c-.3.6-.5 1.3-.5 2s.2 1.4.5 2l1.5-1.1z" fill="#FBBC04"/>
      <path d="M11 12c.6 0 1.2.2 1.6.6l1.2-1.2c-.7-.7-1.7-1.1-2.8-1.1-1.7 0-3.1 1-3.9 2.4l1.5 1.1c.3-1 1.3-1.8 2.4-1.8z" fill="#EA4335"/>
      <text x="26" y="19" font-family="Arial, Helvetica, sans-serif" font-weight="700" font-size="8" fill="#5F6368">Pay</text>
    </svg>
  </span>

  {/* -------- PayPal -------- */}
  <span role="listitem" class="payicon-wrap" title="PayPal">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="PayPal">
      <rect width="48" height="30" rx="4" fill="#fff"/>
      <text x="24" y="19.5" font-family="Arial, Helvetica, sans-serif" font-weight="900" font-style="italic" font-size="9" text-anchor="middle">
        <tspan fill="#003087">Pay</tspan><tspan fill="#009CDE">Pal</tspan>
      </text>
    </svg>
  </span>

  {/* -------- Ticket Restaurant -------- */}
  <span role="listitem" class="payicon-wrap" title="Ticket Restaurant">
    <svg viewBox="0 0 48 30" xmlns="http://www.w3.org/2000/svg" class="payicon" aria-label="Ticket Restaurant">
      <defs>
        <linearGradient id="trgrad" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#E2001A"/>
          <stop offset="1" stop-color="#009FE3"/>
        </linearGradient>
      </defs>
      <rect width="48" height="30" rx="4" fill="url(#trgrad)"/>
      <text x="24" y="13" font-family="Arial, Helvetica, sans-serif" font-weight="900" font-size="5" text-anchor="middle" fill="#fff" letter-spacing="0.2">TICKET</text>
      <text x="24" y="21" font-family="Arial, Helvetica, sans-serif" font-weight="900" font-size="5" text-anchor="middle" fill="#fff" letter-spacing="0.2">RESTAURANT</text>
    </svg>
  </span>
</div>

<style>
  .payicon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 30px;
    width: 48px;
    border-radius: 4px;
    overflow: hidden;
    /* Subtle ring so white-background icons are visible on dark footer */
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
    transition: transform 0.2s var(--ease-out, ease-out);
  }
  .payicon-wrap:hover {
    transform: translateY(-1px);
  }
  .payicon {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
