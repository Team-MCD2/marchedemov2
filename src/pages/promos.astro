---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import PromoCard from "@components/PromoCard.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import NewsletterInline from "@components/NewsletterInline.astro";
import { RAYONS_LIST, SITE } from "@/lib/site";
import { FAQ_HOME } from "@/lib/faqs";
import { breadcrumbSchema } from "@/lib/schema";
import { getActivePromos } from "@/lib/promos-repo";

/* Supabase-first, Content Collection fallback. Featured first. */
const promos = (await getActivePromos()).sort((a, b) =>
  a.data.mise_en_avant === b.data.mise_en_avant ? 0 : a.data.mise_en_avant ? -1 : 1
);

const featured = promos.find((p) => p.data.mise_en_avant);
const others = promos.filter((p) => p !== featured);

const bc = breadcrumbSchema([{ name: "Promos de la semaine", url: "/promos" }]);
---

<Layout
  title={`Promos de la semaine — jusqu'à -40% · ${SITE.name}`}
  description={`${promos.length} offres actives cette semaine sur nos rayons boucherie halal, fruits & légumes, épicerie du monde. Dans nos 2 magasins toulousains.`}
  faqItems={FAQ_HOME}
  schema={bc}
>
  <Breadcrumb items={[{ name: "Promos" }]} />

  <!-- Hero -->
  <section class="bg-rouge text-white pb-10 relative overflow-hidden">
    <div class="container-mo py-12 relative z-10">
      <span class="eyebrow !text-white/80">Promos de la semaine</span>
      <h1 class="display-xl mt-4 text-balance max-w-4xl !text-white">
        <span class="text-white/90">Jusqu'à</span> -40<span class="opacity-80">%</span>
      </h1>
      <p class="mt-6 max-w-xl text-[17px] text-white/85 leading-relaxed">
        <strong>{promos.length} offres</strong> actives cette semaine, mises à jour
        chaque lundi. Valables dans nos 2 magasins toulousains.
      </p>
    </div>

    <!-- Watermark -->
    <div class="absolute -right-20 top-0 bottom-0 w-[560px] opacity-[0.08] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full"><circle cx="7" cy="7" r="1"/><circle cx="17" cy="17" r="1"/><path d="m5 19 14-14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </div>
  </section>

  <!-- Featured promo -->
  {featured && (
    <section class="section-sm bg-blanc">
      <div class="container-mo">
        <span class="eyebrow !text-rouge">Offre de la semaine</span>
        <h2 class="display-md mt-4 max-w-2xl text-balance">Le coup de cœur.</h2>
        <div class="mt-10 max-w-md">
          <PromoCard
            titre={featured.data.titre}
            description={featured.data.description}
            image={featured.data.image}
            prix_original={featured.data.prix_original}
            prix_promo={featured.data.prix_promo}
            reduction_pct={featured.data.reduction_pct}
            rayon={featured.data.rayon}
            magasin={featured.data.magasin}
            date_fin={featured.data.date_fin}
            featured={true}
          />
        </div>
      </div>
    </section>
  )}

  <!-- Grille complète -->
  <section class="section bg-creme">
    <div class="container-mo">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10">
        <div>
          <span class="eyebrow">Toutes les offres</span>
          <h2 class="display-md mt-4 text-balance">Les {others.length} autres promos.</h2>
        </div>
        <!-- Filtres (client-side later) -->
        <div class="flex flex-wrap gap-2" role="tablist" aria-label="Filtrer par rayon">
          <button class="pill pill-vert cursor-pointer" data-filter="all" aria-pressed="true">Tous</button>
          {RAYONS_LIST.slice(0, 5).map((r) => (
            <button class="pill bg-white border border-black/10 cursor-pointer" data-filter={r.slug}>{r.nomCourt}</button>
          ))}
        </div>
      </div>

      <div id="promos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {others.map((p) => (
          <div data-rayon={p.data.rayon}>
            <PromoCard
              titre={p.data.titre}
              description={p.data.description}
              image={p.data.image}
              prix_original={p.data.prix_original}
              prix_promo={p.data.prix_promo}
              reduction_pct={p.data.reduction_pct}
              rayon={p.data.rayon}
              magasin={p.data.magasin}
              date_fin={p.data.date_fin}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <NewsletterInline variant="dark" />
  <FAQAccordion items={FAQ_HOME} />
</Layout>

<script>
  // Simple client-side filter
  const buttons = document.querySelectorAll("[data-filter]");
  const grid = document.getElementById("promos-grid");
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.getAttribute("data-filter");
      buttons.forEach((b) => {
        b.setAttribute("aria-pressed", "false");
        b.classList.remove("pill-vert");
        b.classList.add("bg-white", "border", "border-black/10");
      });
      btn.setAttribute("aria-pressed", "true");
      btn.classList.add("pill-vert");
      btn.classList.remove("bg-white", "border", "border-black/10");
      if (!grid) return;
      grid.querySelectorAll<HTMLElement>("[data-rayon]").forEach((el) => {
        if (filter === "all" || el.getAttribute("data-rayon") === filter) {
          el.style.display = "";
        } else {
          el.style.display = "none";
        }
      });
    });
  });
</script>
