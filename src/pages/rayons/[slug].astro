---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import PromoCard from "@components/PromoCard.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import NewsletterInline from "@components/NewsletterInline.astro";
import TikTokEmbed from "@components/islands/TikTokEmbed.jsx";
import { getCollection } from "astro:content";
import { RAYONS, RAYONS_LIST, SITE, type RayonSlug } from "@/lib/site";
import { faqsForRayon } from "@/lib/faqs";
import { breadcrumbSchema } from "@/lib/schema";
import { supabase } from "@/lib/supabase";
import { getPromosForRayon } from "@/lib/promos-repo";
import tiktokEmbeds from "@/generated/tiktok-embeds.json";

export async function getStaticPaths() {
  return Object.values(RAYONS).map((r) => ({ params: { slug: r.slug } }));
}

const { slug } = Astro.params as { slug: RayonSlug };
const rayon = RAYONS[slug];
if (!rayon) throw new Error(`Rayon non trouvé : ${slug}`);

const isCulturel = rayon.culturel;
/* Cultural heroes use dark backgrounds with light text; non-cultural stay on light bg. */
const heroTheme = isCulturel ? "rayon-hero--dark" : "rayon-hero--light";

/* Promos du rayon — Supabase-first via repo, fallback Content Collection */
const promos = await getPromosForRayon(slug);

/* Videos du rayon */
const videos = (await getCollection("videos"))
  .filter((v) => v.data.actif && v.data.rayon === slug)
  .sort((a, b) => a.data.ordre - b.data.ordre);

/* Catalogue (Supabase) — fetched at build time for this rayon.
   Public anon key enforces RLS : only actif=true rows are returned.
   Field list kept minimal to keep the payload small. */
type CatalogueRow = {
  id: string;
  slug: string;
  nom: string;
  image_url: string | null;
  badge: string | null;
  origine: string | null;
  unite: string | null;
  description: string | null;
};

let catalogue: CatalogueRow[] = [];
try {
  const { data, error } = await supabase
    .from("produits")
    .select("id, slug, nom, image_url, badge, origine, unite, description")
    .eq("rayon", slug)
    .order("ordre", { ascending: true })
    .order("nom", { ascending: true });
  if (error) {
    console.warn(`[rayon ${slug}] Supabase produits error :`, error.message);
  } else {
    catalogue = data ?? [];
  }
} catch (e: any) {
  console.warn(`[rayon ${slug}] Supabase unreachable :`, e?.message || e);
}

/* Group by badge (sub-category) so the catalogue is scannable by family.
   Produits without a badge are grouped under "Autres". */
const catalogueGroups = (() => {
  const m = new Map<string, CatalogueRow[]>();
  for (const p of catalogue) {
    const key = p.badge?.trim() || "Autres";
    if (!m.has(key)) m.set(key, []);
    m.get(key)!.push(p);
  }
  /* Stable order : named sub-categories by fr-FR locale, "Autres" last. */
  return Array.from(m.entries()).sort((a, b) => {
    if (a[0] === "Autres") return 1;
    if (b[0] === "Autres") return -1;
    return a[0].localeCompare(b[0], "fr");
  });
})();

/* Previous approach (readdirSync over /images/rayons/<slug>/) produced
 * wrong images because most subfolder files are AMBIANCE shots
 * (landscapes, portraits, 'traçabilité' barcodes) pulled from the Wix
 * scrape, not product shots. Showing a mountain photo next to "Attiéké
 * précuit" was misleading, so the pool is removed entirely.
 *
 * New policy : show the real product photo when `image_url` is set,
 * otherwise render a clean branded placeholder card (see below).
 * Never guess-and-hope with a random scene.
 *
 * Admins curate product photos via /admin/medias + /admin/produits. */

/* Other rayons pour cross-linking */
const otherRayons = RAYONS_LIST.filter((r) => r.slug !== slug).slice(0, 4);

const bc = breadcrumbSchema([
  { name: "Nos rayons", url: "/rayons" },
  { name: rayon.nom, url: `/rayons/${slug}` },
]);

const faqItems = faqsForRayon(slug);

/* Slideshow hero : identique à la RayonCard home — ≥ 2 images → crossfade CSS. */
const uniqueSlides = Array.from(new Set(rayon.heroSlideshow ?? []));
const slideshowActive = uniqueSlides.length >= 2;
const slideCount = Math.min(uniqueSlides.length, 4);
---

<Layout
  title={`${rayon.nom} · Marché de Mo' — ${rayon.keywords[0]}`}
  description={rayon.description}
  faqItems={faqItems}
  schema={bc}
  heroImage={rayon.image}
  bodyDataRayon={slug}
>
  <!-- Breadcrumb (dark if cultural hero dark) -->
  <Breadcrumb
    items={[
      { name: "Nos rayons", href: "/rayons" },
      { name: rayon.nom },
    ]}
  />

  <!-- HERO -->
  <section class={`rayon-hero ${heroTheme} relative overflow-hidden`}>
    <!-- Motif culturel (pattern via CSS var par rayon) -->
    <div class="rayon-motif absolute inset-0 pointer-events-none"></div>

    <div class="container-mo relative z-10 py-14 md:py-20 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <span class="eyebrow rayon-eyebrow">
          {rayon.eyebrow}
        </span>
        <h1 class="display-xl mt-4 text-balance rayon-title">
          {rayon.nom}
        </h1>
        <p class="mt-6 text-[18px] md:text-[20px] leading-snug max-w-2xl rayon-tagline">
          {rayon.tagline}
        </p>
        <p class="mt-4 text-[15px] leading-relaxed max-w-2xl rayon-lead">
          {rayon.longDescription}
        </p>

        <div class="mt-8 flex flex-wrap gap-2">
          {rayon.featured.map((f) => (
            <span class="pill rayon-pill">{f}</span>
          ))}
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-3">
          <a href="/magasins" class="btn rayon-btn-primary">
            Trouver un magasin
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          {promos.length > 0 && (
            <a href="#promos" class="btn rayon-btn-ghost">
              Voir les {promos.length} promo{promos.length > 1 ? "s" : ""}
            </a>
          )}
          {catalogue.length > 0 && (
            <a href="#catalogue" class="btn rayon-btn-ghost">
              Voir le catalogue ({catalogue.length})
            </a>
          )}
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="relative aspect-[4/5] rounded-[40px] overflow-hidden shadow-2xl ring-1 ring-black/5">
          {slideshowActive ? (
            <div class="rayon-slideshow absolute inset-0" data-slides={slideCount}>
              {uniqueSlides.slice(0, 4).map((src, i) => (
                <img
                  src={src}
                  alt={i === 0 ? rayon.imageAlt : ""}
                  aria-hidden={i > 0 ? "true" : undefined}
                  class="rayon-slide"
                  fetchpriority={i === 0 ? "high" : undefined}
                  loading={i === 0 ? undefined : "lazy"}
                  width="800"
                  height="1000"
                  decoding="async"
                />
              ))}
            </div>
          ) : (
            <img
              src={rayon.image}
              alt={rayon.imageAlt}
              class="w-full h-full object-cover"
              fetchpriority="high"
              width="800"
              height="1000"
              decoding="async"
            />
          )}
          <!-- Overlay subtil couleur accent -->
          <div class="rayon-img-overlay absolute inset-0 pointer-events-none"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROMOS du rayon -->
  {promos.length > 0 && (
    <section id="promos" class="section bg-blanc">
      <div class="container-mo">
        <span class="eyebrow !text-rouge">Promos {rayon.nomCourt}</span>
        <h2 class="display-md mt-4 max-w-2xl text-balance">Les offres du rayon cette semaine.</h2>

        <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {promos.map((p) => (
            <PromoCard
              titre={p.data.titre}
              description={p.data.description}
              image={p.data.image}
              prix_original={p.data.prix_original}
              prix_promo={p.data.prix_promo}
              reduction_pct={p.data.reduction_pct}
              rayon={p.data.rayon}
              magasin={p.data.magasin}
              date_fin={p.data.date_fin}
              featured={p.data.mise_en_avant}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CATALOGUE du rayon — groupé par sous-catégorie (badge) -->
  {catalogue.length > 0 && (
    <section id="catalogue" class="section bg-creme">
      <div class="container-mo">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
          <div class="max-w-2xl">
            <span class="eyebrow">Notre offre</span>
            <h2 class="display-md mt-4 text-balance">
              {catalogue.length} produits représentatifs<br/>
              <span class="text-vert">au rayon {rayon.nomCourt}.</span>
            </h2>
            <p class="mt-3 text-[15px] text-neutral-600 leading-relaxed">
              Aperçu non-exhaustif. Les prix sont affichés en rayon, à l'euro près.
              {promos.length > 0 && (
                <span> Voir les <a href="#promos" class="underline hover:text-rouge">{promos.length} promo{promos.length > 1 ? "s" : ""}</a> en cours.</span>
              )}
            </p>
          </div>
          <div class="flex items-center gap-2 text-[13px] text-neutral-500">
            <span class="inline-flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-vert animate-pulse" aria-hidden="true"></span>
              Mis à jour en temps réel
            </span>
          </div>
        </div>

        <div class="space-y-10 md:space-y-12">
          {catalogueGroups.map(([badge, items]) => (
            <section>
              <div class="flex items-baseline justify-between gap-4 flex-wrap mb-5">
                <h3 class="font-soft font-bold text-[20px] md:text-[24px] text-noir inline-flex items-center gap-3">
                  <span class="inline-block w-1 h-6 bg-vert rounded-full" aria-hidden="true"></span>
                  {badge}
                </h3>
                <span class="text-[12px] text-neutral-400 font-pro uppercase tracking-wider">
                  {items.length} produit{items.length > 1 ? "s" : ""}
                </span>
              </div>

              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4">
                {items.map((p) => (
                  <article class="produit-card group">
                    <div class="relative aspect-square rounded-2xl overflow-hidden ring-1 ring-black/5 shadow-sm group-hover:shadow-card-hover group-hover:-translate-y-0.5 transition-all duration-300">
                      {p.image_url ? (
                        <img
                          src={p.image_url}
                          alt={p.nom}
                          loading="lazy"
                          decoding="async"
                          width="400"
                          height="400"
                          class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500"
                        />
                      ) : (
                        <div class="absolute inset-0 bg-gradient-to-br from-creme via-creme-warm to-[#EEEAE0] flex flex-col items-center justify-center p-4 text-center">
                          <img
                            src="/logos/favicon-marchedemo.png"
                            alt=""
                            aria-hidden="true"
                            width="48"
                            height="48"
                            class="w-10 h-10 md:w-12 md:h-12 opacity-15 mb-2"
                            loading="lazy"
                          />
                          <p class="font-soft font-bold text-[11px] md:text-[12px] leading-tight text-neutral-500 uppercase tracking-wider line-clamp-3">
                            {p.nom}
                          </p>
                          <span class="mt-2 text-[9.5px] text-neutral-400 italic">Photo à venir</span>
                        </div>
                      )}
                      {p.origine && (
                        <span class="absolute top-2 left-2 inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-white/95 backdrop-blur text-[10.5px] font-bold text-noir shadow-sm">
                          {p.origine}
                        </span>
                      )}
                    </div>
                    <div class="mt-3 px-0.5">
                      <p class="font-soft font-bold text-[13.5px] md:text-[14px] leading-tight text-noir line-clamp-2 min-h-[2.4em]">
                        {p.nom}
                      </p>
                      <p class="text-[11.5px] text-neutral-500 mt-1 leading-snug">
                        {p.unite && <span class="font-bold text-neutral-700">{p.unite}</span>}
                        {p.unite && p.description && <span> · </span>}
                        {p.description && <span class="line-clamp-1">{p.description}</span>}
                      </p>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>

        <p class="mt-8 text-[12px] text-neutral-400 leading-relaxed max-w-3xl">
          <strong class="text-neutral-600">Note :</strong> ce catalogue présente des produits représentatifs du rayon. La disponibilité réelle peut varier selon le magasin et l'arrivage. Pour une demande spécifique ou un produit que vous ne voyez pas ici, contactez-nous via le chat en bas à droite.
        </p>
      </div>
    </section>
  )}

  <!-- VIDEOS du rayon -->
  {videos.length > 0 && (
    <section class="section bg-creme">
      <div class="container-mo">
        <span class="eyebrow">En vidéo</span>
        <h2 class="display-md mt-4 max-w-2xl text-balance">Découvrez le rayon en images.</h2>

        <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl">
          {videos.map((v) => {
            const cached = tiktokEmbeds[v.data.id];
            return (
              <TikTokEmbed
                client:visible
                url={v.data.url_tiktok}
                title={v.data.titre}
                thumbnail={cached?.thumbnail ?? v.data.thumbnail}
                embedHtml={cached?.html}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- AUTRES RAYONS -->
  <section class="section bg-blanc border-t border-black/5">
    <div class="container-mo">
      <span class="eyebrow">Continuer l'exploration</span>
      <h2 class="display-md mt-4 max-w-2xl text-balance">Autres rayons à découvrir.</h2>

      <div class="mt-10 grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
        {otherRayons.map((r) => (
          <a
            href={`/rayons/${r.slug}`}
            class="group relative rounded-2xl overflow-hidden aspect-[4/5] bg-noir"
          >
            <img
              src={r.image}
              alt={r.imageAlt}
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover opacity-75 group-hover:opacity-90 group-hover:scale-[1.06] transition-all duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-4 md:p-5">
              <h3 class="font-soft font-bold text-white text-[16px] md:text-[20px] leading-tight">
                {r.nomCourt}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <NewsletterInline />
  <FAQAccordion items={faqItems} title={`FAQ — ${rayon.nomCourt}`} />
</Layout>
