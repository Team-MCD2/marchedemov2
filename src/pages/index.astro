---
import Layout from "@layouts/Layout.astro";
import RayonCard from "@components/RayonCard.astro";
import PromoCard from "@components/PromoCard.astro";
import ProduitCard from "@components/ProduitCard.astro";
import RecetteCard from "@components/RecetteCard.astro";
import Stats from "@components/Stats.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import NewsletterInline from "@components/NewsletterInline.astro";
import LocalVideoPlayer from "@components/islands/LocalVideoPlayer.jsx";
import PromoCarousel from "@components/PromoCarousel.astro";
import PromoHero, { type ExtraSlide } from "@components/PromoHero.astro";
import ActuCarousel from "@components/ActuCarousel.astro";
import KineticMarquee from "@components/KineticMarquee.astro";
import { getActus } from "@/lib/actus";
import { getCollection } from "astro:content";
import { RAYONS_LIST, ENGAGEMENTS, MAGASINS, SITE } from "@/lib/site";
import { getRecettesVedettes } from "@/lib/recettes";
import { FAQ_HOME } from "@/lib/faqs";
import { organizationSchema, websiteSchema, allMagasinsSchema, offerSchema } from "@/lib/schema";
import { getActivePromos } from "@/lib/promos-repo";
import { getProduitsVedettes } from "@/lib/produits-repo";

/* Promos : Supabase-first (actif=true), fallback Content Collection.
   featuredPromo = first mise_en_avant row, used for OfferSchema JSON-LD. */
const allPromos = await getActivePromos();
const featuredPromo = allPromos.find((p) => p.data.mise_en_avant) ?? allPromos[0];
const promosHome = allPromos.slice(0, 6);
const promosHero = allPromos.filter((p) => p.data.mise_en_avant).slice(0, 4);

/* Editorial slides for PromoHero — non-promo narratives (app, fidelity,
   new store). Shown after the mise_en_avant promos. */
const heroEditorialSlides: ExtraSlide[] = [
  {
    kind: "editorial",
    eyebrow: "Dernier-né du Groupe",
    titre: "Toulouse Sud Cépière. Ouvert.",
    description:
      "1 200 m² d'espace de vente, rayon Saveurs d'Asie étendu, espace traiteur halal sur place. Votre nouveau rendez-vous au cœur de l'Hippodrome.",
    image: "/images/magasins/toulouse-sud.jpg",
    imageAlt: "Nouveau magasin Marché de Mo' Toulouse Sud Cépière",
    ctaLabel: "Découvrir le magasin",
    ctaHref: "/magasins/toulouse-sud",
    accent: "#1C6B35",
  },
  {
    kind: "editorial",
    eyebrow: "Programme fidélité",
    titre: "5€ offerts à chaque 100€.",
    description:
      "La carte Marché de Mo' : un avantage direct, sans condition. Vous faites vos courses, on vous remercie.",
    image: "/images/rayons/fruits-legumes.jpg",
    imageAlt: "Carte fidélité Marché de Mo'",
    ctaLabel: "Rejoindre le programme",
    ctaHref: "/fidelite",
    accent: "#C53030",
  },
];

/* Produits vedettes : Supabase-first (ordre asc), fallback static list. */
const PRODUITS_VEDETTES = await getProduitsVedettes(8);

/* Actus du marché — stream unifié (articles + recettes + arrivages +
   nouveautés + événements), pattern Grand Frais. Agrégé via lib/actus.ts,
   affiché en carousel horizontal. */
const actus = await getActus(12);

/* Recettes vedettes : celles avec mise_en_avant=true dans la Collection,
   3-6 max pour la section "Cuisinez le monde" en bas de page. */
const recettesHome = await getRecettesVedettes(3);

/* Videos home */
const videos = (await getCollection("videos", (v) => v.data.actif && v.data.rayon === "home"))
  .sort((a, b) => a.data.ordre - b.data.ordre);

const schemas = [
  organizationSchema(),
  websiteSchema(),
  ...allMagasinsSchema(),
  ...(featuredPromo ? [offerSchema(featuredPromo.data)] : []),
];
---

<Layout
  title={`${SITE.name} — Plus grand supermarché ethnique d'Occitanie · Toulouse`}
  description={SITE.shortPitch + ". Boucherie halal, fruits & légumes exotiques, épices du monde — 2 magasins à Toulouse."}
  faqItems={FAQ_HOME}
  schema={schemas}
  heroImage="/images/rayons/epices-du-monde/marche-aux-epices-dubai.jpg"
>
  {/* ====================== 1 · HERO ====================== */}
  <section class="relative overflow-hidden bg-gradient-to-br from-white via-creme to-[#F7F5F0]">
    <!-- Watermark Mo' — parallax léger pour feel "profondeur" -->
    <img
      src="/logos/favicon-marchedemo.png"
      alt=""
      aria-hidden="true"
      data-parallax="0.45"
      class="absolute -right-20 top-10 w-[640px] max-w-[70%] opacity-[0.045] pointer-events-none select-none"
    />
    <div class="container-mo relative z-10 pt-12 lg:pt-20 pb-20 lg:pb-28 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <span class="eyebrow">Supermarché ethnique · Toulouse</span>
        <h1 class="display-xl mt-6 text-balance" data-split-reveal>
          <span class="text-vert">Saveurs</span> du monde.<br/>
          Prix de <span class="text-rouge">quartier</span>.
        </h1>
        <p class="mt-6 max-w-xl text-[17px] leading-relaxed text-neutral-600 text-pretty">
          <strong>10 000 références</strong> — boucherie halal sur carcasse, fruits
          &amp; légumes exotiques, épices du monde — aux prix les plus serrés d'Occitanie.
          <strong>2 magasins</strong> à Toulouse, ouverts <strong>7j/7</strong>.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-3">
          <a href="/rayons" class="btn btn-primary btn-sheen">
            Voir les 10 rayons
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/magasins" class="btn btn-ghost">Trouver le magasin</a>
        </div>

        <!-- Trust indicators (4 pills) -->
        <div class="mt-12 flex flex-wrap items-center gap-x-6 gap-y-3 text-[13px] text-neutral-500">
          <span class="inline-flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-vert"></span> Halal certifié, sans électronarcose</span>
          <span class="inline-flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-rouge"></span> Arrivage quotidien</span>
          <span class="inline-flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-noir"></span> Prix affichés en rayon</span>
          <a
            href="/rayons/produits-courants"
            class="inline-flex items-center gap-2 group hover:text-rouge transition-colors"
          >
            <span class="w-2 h-2 rounded-full bg-rouge animate-pulse"></span>
            <strong class="font-bold">Des prix cassés</strong>
            <span class="text-rouge group-hover:translate-x-0.5 transition-transform">→</span>
          </a>
        </div>
      </div>

      <!-- Hero visual : phone mockup montrant le site sur téléphone.
           Le screen est une vraie capture mobile de la home rendue à 360×780
           via Playwright (script: scripts/capture-mobile-home.mjs).
           Pour rafraîchir la capture après un changement de hero :
             1. npm run dev
             2. node scripts/capture-mobile-home.mjs -->
      <div class="lg:col-span-5 relative flex items-center justify-center pt-4 lg:pt-0">
        <div class="phone-mockup">
          <div class="phone-mockup-screen">
            <div class="phone-screen-content relative">
              <img
                src="/images/home/mobile-home-screen.jpg"
                alt="Aperçu du site Marché de Mo' sur téléphone"
                fetchpriority="high"
                width="360"
                height="780"
                class="absolute inset-0 w-full h-full object-cover"
              />
              <!-- Liseré intérieur pour la profondeur de l'écran. -->
              <div class="absolute inset-0 ring-1 ring-inset ring-black/10 pointer-events-none"></div>
            </div>
          </div>
        </div>

        <!-- Sticker logo rouge en surcouche -->
        <img
          src="/logos/logo-marchedemo-FDROUGE.png"
          alt=""
          aria-hidden="true"
          class="absolute top-2 right-4 lg:right-0 w-24 md:w-28 drop-shadow-2xl rotate-[8deg] z-10 pointer-events-none"
        />
        <!-- Floating badge "Disponible sur téléphone" -->
        <div class="absolute -left-2 md:-left-6 bottom-12 bg-white rounded-2xl shadow-2xl p-3 md:p-4 flex items-center gap-3 max-w-[240px] z-10">
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-vert/10 flex items-center justify-center text-vert shrink-0">
            <svg class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="2" width="14" height="20" rx="2"/>
              <line x1="12" y1="18" x2="12" y2="18.01"/>
            </svg>
          </div>
          <div>
            <div class="font-soft font-bold text-[14px] md:text-[15px] leading-tight">Pensé mobile</div>
            <div class="text-[11px] md:text-[12px] text-neutral-500 leading-tight mt-0.5">Notre site, sur<br/>votre téléphone</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ====================== 2 · PROMO HERO (banner carousel full-width) ====================== */}
  {/* Full-width hero-style carousel : featured promos + editorial slides.
      One slide visible at a time with auto-advance, drag, dots. */}
  <PromoHero
    promos={promosHero}
    extraSlides={heroEditorialSlides}
    autoAdvanceMs={6000}
  />

  {/* ====================== 3 · TICKER PROMO (urgency strip) ====================== */}
  {featuredPromo && (
    <section class="relative overflow-hidden bg-rouge text-white">
      <div class="container-mo py-4 md:py-5 flex flex-wrap items-center gap-x-6 gap-y-2 text-[13px] md:text-[14px] font-pro">
        <span class="inline-flex items-center gap-2 font-bold">
          <span class="badge-promo !bg-white !text-rouge !shadow-none !min-w-0 !h-auto !px-2 !py-0.5 !text-[12px]">
            -{featuredPromo.data.reduction_pct}%
          </span>
          Offre de la semaine
        </span>
        <span>
          <strong>{featuredPromo.data.titre}</strong> ·
          {featuredPromo.data.prix_promo} € au lieu de {featuredPromo.data.prix_original} €
        </span>
        <a href="/promos" class="ml-auto font-bold underline underline-offset-4 hover:opacity-80 transition">
          Voir toutes les promos →
        </a>
      </div>
    </section>
  )}

  {/* ====================== PROMOS DE LA SEMAINE — IMPULSE BUY ====================== */}
  {/* Remonté de la position 8 à la position 3 : 'désir d'achat dans les 3 secondes'. */}
  {promosHome.length > 0 && (
    <section class="section bg-creme">
      <div class="container-mo">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 reveal">
          <div class="max-w-2xl">
            <span class="eyebrow !text-rouge">Promos de la semaine</span>
            <h2 class="display-lg mt-4 text-balance">
              Les <span class="text-rouge">vraies promos</span> du moment.
            </h2>
            <p class="mt-3 text-[15px] text-neutral-600">
              Mises à jour chaque semaine. Affichées à l'euro près, dans nos 2 magasins.
            </p>
          </div>
          <a href="/promos" class="btn btn-rouge shrink-0">
            Voir toutes les promos
          </a>
        </div>

        <PromoCarousel promos={promosHome} />
      </div>
    </section>
  )}

  {/* ====================== NOS 10 RAYONS ====================== */}
  <section class="section bg-blanc">
    <div class="container-mo">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 reveal">
        <div class="max-w-2xl">
          <span class="eyebrow">Nos 10 rayons</span>
          <h2 class="display-lg mt-4 text-balance">
            10 rayons. 10 000 références.<br/>
            <span class="text-vert">Un seul ticket de caisse.</span>
          </h2>
        </div>
        <a href="/rayons" class="btn btn-secondary shrink-0 btn-sheen">
          Voir tous les rayons
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {RAYONS_LIST.slice(0, 6).map((r, i) => (
          <RayonCard rayon={r} large={i === 0} />
        ))}
      </div>
    </div>
  </section>

  {/* ====================== KINETIC MARQUEE — chapter break signature ======================
      Typographie display massive qui défile. Casse le rythme visuel après
      le mur des 10 rayons et annonce le chapitre "actualités". */}
  <KineticMarquee
    items={[
      "Saveurs du monde",
      "Arrivages quotidiens",
      "Boucherie halal sur carcasse",
      "Fruits exotiques",
      "10 000+ références",
      "Depuis 2012 à Toulouse",
    ]}
    variant="vert"
    speed={25}
  />

  {/* ====================== ACTUS DU MARCHÉ — carousel unifié (pattern Grand Frais) ======================
      Stream agrégé : articles éditoriaux, recettes, arrivages saisonniers,
      nouveautés catalogue, événements magasin. Toutes les cards suivent le
      même format (image + badge rayon + titre) pour cohérence visuelle.
      Auto-scroll lent, swipe, drag, flèches, keyboard — tout accessible. */}
  {actus.length > 0 && (
    <section class="section bg-blanc relative overflow-hidden">
      <div class="container-mo">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 reveal">
          <div class="max-w-2xl">
            <span class="eyebrow">Les actus du marché</span>
            <h2 class="display-lg mt-4 text-balance" data-split-reveal>
              Ce qui <span class="text-vert">bouge</span><br/>
              en ce moment.
            </h2>
            <p class="mt-3 text-[15px] text-neutral-600">
              Arrivages de saison, nouveautés en rayon, événements, recettes d'inspiration.
              Le pouls du marché, chaque semaine.
            </p>
          </div>
          <a href="/actualites" class="btn btn-secondary shrink-0 btn-sheen">
            Toutes les actus
          </a>
        </div>

        <ActuCarousel actus={actus} />
      </div>
    </section>
  )}

  {/* ====================== PRODUITS VEDETTES — vitrine sans prix ====================== */}
  <section class="section bg-creme">
    <div class="container-mo">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 reveal">
        <div class="max-w-2xl">
          <span class="eyebrow">Produits vedettes</span>
          <h2 class="display-lg mt-4 text-balance">
            Du <span class="text-vert">monde entier</span>,<br/>
            dans votre panier.
          </h2>
          <p class="mt-3 text-[15px] text-neutral-600">
            Notre sélection du moment, rayon par rayon. Prix affichés à l'euro près en magasin.
          </p>
        </div>
        <a href="/rayons" class="btn btn-secondary shrink-0 btn-sheen">
          Explorer les rayons
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-5">
        {PRODUITS_VEDETTES.map((p, i) => (
          <div class="reveal" style={`--reveal-delay: ${(i % 4) * 60}ms`}>
            <ProduitCard produit={p} />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ====================== STATS — chiffres rassurance ====================== */}
  <Stats variant="light" />

  {/* ====================== QUI EST MO' — émotionnel ====================== */}
  <section class="section bg-noir-section relative overflow-hidden">
    <img
      src="/logos/favicon-marchedemo-contourwh.png"
      alt=""
      aria-hidden="true"
      class="absolute -right-20 top-10 w-[640px] max-w-[80%] opacity-[0.06] pointer-events-none select-none"
    />
    <div class="container-mo relative z-10 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <span class="eyebrow !text-vert-light">Notre histoire</span>
        <h2 class="display-lg mt-4 text-balance !text-white">
          Mo', c'était<br/>
          <span class="text-vert-light">Mohammed</span>.
        </h2>
        <div class="mt-6 space-y-4 text-white/75 text-[16px] leading-relaxed max-w-2xl">
          <p>
            Le patriarche. Le père de cette famille de commerçants passionnés
            dont est issu <strong class="text-white">Samir Ouaddaha</strong>,
            fondateur du Marché de Mo'.
          </p>
          <p>
            Lauréat du <strong class="text-white">Réseau Entreprendre Occitanie</strong>,
            Samir a ouvert le premier magasin en août 2024 à Portet-sur-Garonne.
            Avec une conviction simple : les saveurs du monde doivent être
            accessibles à tous, avec la <strong class="text-white">qualité d'un ultra-frais</strong>
            et le prix d'un supermarché.
          </p>
          <p>
            Aujourd'hui, 2 magasins, <strong class="text-white">24 salariés</strong>,
            et une certitude : <strong class="text-white">90% de notre équipe</strong>
            n'avait pas d'emploi avant de rejoindre le Marché de Mo'.
          </p>
        </div>
        <div class="mt-10 flex flex-col sm:flex-row gap-3">
          <a href="/notre-enseigne" class="btn btn-primary btn-sheen">Notre enseigne</a>
          <a href="/nos-engagements" class="btn btn-ghost !text-white !border-white/25 hover:!border-white">
            Nos engagements
          </a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="relative aspect-square rounded-full overflow-hidden bg-gradient-to-br from-vert-dark/40 to-black/60 ring-4 ring-white/10 reveal reveal-mask">
          <img
            src="/images/home/fondateur-mo.png"
            alt="Mohammed — le père, patriarche de la famille fondatrice du Marché de Mo'"
            class="absolute inset-0 w-full h-full object-contain object-bottom p-6"
            width="900"
            height="900"
            loading="lazy"
          />
          <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/40 to-transparent"></div>
        </div>
      </div>
    </div>
  </section>

  {/* ====================== ENGAGEMENTS — trust ====================== */}
  <section class="section bg-creme">
    <div class="container-mo">
      <div class="text-center max-w-3xl mx-auto mb-14 reveal">
        <span class="eyebrow !justify-center">Nos 4 engagements</span>
        <h2 class="display-lg mt-4 text-balance">
          Un supermarché, oui.<br/>
          <span class="text-rouge">Un engagement</span>, surtout.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
        {ENGAGEMENTS.map((e, i) => (
          <article
            class="bg-white rounded-3xl p-8 shadow-card hover:shadow-card-hover transition-all duration-300 hover:-translate-y-1 reveal"
            style={`--reveal-delay: ${i * 80}ms`}
          >
            <div class="w-14 h-14 rounded-2xl bg-vert/10 text-vert flex items-center justify-center mb-6">
              {e.icone === "heart" && (
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              )}
              {e.icone === "people" && (
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              )}
              {e.icone === "trophy" && (
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6M18 9h1.5a2.5 2.5 0 0 0 0-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22M18 2H6v7a6 6 0 0 0 12 0V2z"/>
                </svg>
              )}
              {e.icone === "care" && (
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  <path d="M12 7v4M9 9h6"/>
                </svg>
              )}
            </div>
            <h3 class="font-soft font-bold text-[20px] leading-tight">{e.titre}</h3>
            <p class="mt-2 text-[14px] text-neutral-500 font-pro">{e.resume}</p>
            <p class="mt-4 text-[14px] text-neutral-700 leading-relaxed">{e.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ====================== VIDEOS TIKTOK — social proof ====================== */}
  {videos.length > 0 && (
    <section class="section bg-blanc">
      <div class="container-mo">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 reveal">
          <div class="max-w-2xl">
            <span class="eyebrow">Marché de Mo' en vidéos</span>
            <h2 class="display-lg mt-4 text-balance">
              Rencontrez nos équipes et nos rayons.
            </h2>
          </div>
          <a href="https://www.tiktok.com/@marchedemo" target="_blank" rel="noopener noreferrer" class="btn btn-secondary shrink-0">
            Nous suivre sur TikTok
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {videos.slice(0, 3).map((v) => {
            return (
              <LocalVideoPlayer
                client:visible
                src={v.data.src_local}
                title={v.data.titre}
                href={v.data.url_tiktok}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* ====================== RECETTES — inspiration use-case ====================== */}
  <section class="section bg-creme">
    <div class="container-mo">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 reveal">
        <div class="max-w-2xl">
          <span class="eyebrow">Recettes du monde</span>
          <h2 class="display-lg mt-4 text-balance">
            Cuisinez la planète,<br/>
            <span class="text-vert">avec nos rayons.</span>
          </h2>
          <p class="mt-3 text-[15px] text-neutral-600">
            Mafé sénégalais, bibimbap coréen, tajine marocain, phở vietnamien…
            Recettes authentiques, ingrédients en rayon, explications pas à pas.
          </p>
        </div>
        <a href="/recettes" class="btn btn-secondary shrink-0 btn-sheen">
          Toutes les recettes
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {recettesHome.map((r, i) => (
          <div class="reveal" style={`--reveal-delay: ${i * 80}ms`}>
            <RecetteCard recette={r} />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ====================== MAGASINS — conversion logistique ====================== */}
  <section class="section bg-blanc">
    <div class="container-mo">
      <div class="text-center max-w-3xl mx-auto mb-14 reveal">
        <span class="eyebrow !justify-center">Nos magasins</span>
        <h2 class="display-lg mt-4 text-balance">
          2 magasins à Toulouse.<br/>
          <span class="text-vert">Ouverts 7j/7, même dimanche matin.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        {Object.values(MAGASINS).map((m) => (
          <a
            href={`/magasins/${m.slug}`}
            class="group relative overflow-hidden rounded-3xl bg-noir text-white shadow-xl hover:shadow-2xl transition-all duration-500"
          >
            <div class="aspect-[16/10] relative overflow-hidden bg-noir-softer">
              <img
                src={m.photo || "/images/magasins/portet.jpg"}
                alt={`${m.nom} — extérieur`}
                loading="lazy"
                width="1200"
                height="750"
                class="w-full h-full object-cover opacity-70 group-hover:opacity-85 group-hover:scale-[1.05] transition-all duration-700"
                onerror="this.style.opacity='0.3'"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
              {m.badge && (
                <span class="absolute top-5 left-5 pill pill-rouge bg-rouge !text-white">
                  {m.badge}
                </span>
              )}
            </div>
            <div class="absolute inset-x-0 bottom-0 p-7 lg:p-10">
              <h3 class="font-soft font-bold text-[26px] lg:text-[32px] leading-tight">
                {m.nomCourt}
              </h3>
              <p class="mt-2 text-white/80 text-[14px]">{m.adresseLigne1}, {m.codePostal} {m.ville}</p>
              <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-1 text-[12.5px] text-white/70">
                <span class="inline-flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  7j/7
                </span>
                <span>{m.surface}</span>
                <span>{m.parking}</span>
              </div>
              <span class="mt-6 inline-flex items-center gap-2 font-bold text-[13.5px] group-hover:translate-x-1 transition-transform">
                Voir le magasin
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ====================== NEWSLETTER ====================== */}
  <NewsletterInline variant="dark" />

  {/* ====================== FAQ ====================== */}
  <FAQAccordion items={FAQ_HOME} />
</Layout>
