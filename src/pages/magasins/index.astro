---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import NewsletterInline from "@components/NewsletterInline.astro";
import { SITE, MAGASINS } from "@/lib/site";
import { FAQ_HOME } from "@/lib/faqs";
import { breadcrumbSchema, allMagasinsSchema } from "@/lib/schema";

const bc = breadcrumbSchema([{ name: "Magasins", url: "/magasins" }]);
---

<Layout
  title={`Nos 2 magasins à Toulouse — Portet & Cépière · ${SITE.name}`}
  description="Nos 2 magasins à Toulouse : Portet-sur-Garonne (8 Allée Pablo Picasso) et Toulouse Sud — Cépière (centre commercial L'Hippodrome). Ouverts 7j/7, parking gratuit."
  faqItems={FAQ_HOME}
  schema={[bc, ...allMagasinsSchema()]}
>
  <Breadcrumb items={[{ name: "Magasins" }]} />

  <!-- Hero -->
  <section class="bg-blanc pb-8">
    <div class="container-mo">
      <span class="eyebrow">Nos magasins</span>
      <h1 class="display-xl mt-4 text-balance max-w-4xl">
        2 magasins.<br/>
        <span class="text-vert">Une seule</span> philosophie.
      </h1>
      <p class="mt-6 max-w-2xl text-[17px] text-neutral-600 leading-relaxed">
        Portet-sur-Garonne et Toulouse Sud — Cépière. Deux adresses, deux ambiances,
        un même engagement sur la qualité, le halal certifié et les saveurs du monde.
      </p>
    </div>
  </section>

  <!-- Grille 2 magasins -->
  <section class="section-sm bg-blanc">
    <div class="container-mo grid lg:grid-cols-2 gap-6 lg:gap-8">
      {Object.values(MAGASINS).map((m) => (
        <a
          href={`/magasins/${m.slug}`}
          class="group relative overflow-hidden rounded-3xl bg-noir text-white shadow-xl hover:shadow-2xl transition-all duration-500"
        >
          <div class="aspect-[16/11] relative overflow-hidden bg-noir-softer">
            <img
              src={m.photo || "https://images.unsplash.com/photo-1604719312566-8912e9227c6a?auto=format&fit=crop&w=1400&q=85"}
              alt={`${m.nom} — devanture`}
              class="w-full h-full object-cover opacity-70 group-hover:opacity-85 group-hover:scale-[1.05] transition-all duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
            {m.badge && (
              <span class="absolute top-5 left-5 pill pill-rouge bg-rouge !text-white">{m.badge}</span>
            )}
          </div>
          <div class="absolute inset-x-0 bottom-0 p-8 lg:p-10">
            <h2 class="font-soft font-bold text-[28px] lg:text-[36px] leading-tight">{m.nomCourt}</h2>
            <p class="mt-2 text-white/80 text-[15px]">{m.adresseLigne1}, {m.codePostal} {m.ville}</p>
            <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-1 text-[13px] text-white/75">
              <span>{m.surface}</span>
              <span>{m.parking}</span>
              <span>7j/7</span>
            </div>
            <span class="mt-6 inline-flex items-center gap-2 font-bold text-[14px] group-hover:translate-x-1 transition-transform">
              Voir le magasin
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <NewsletterInline />
  <FAQAccordion items={FAQ_HOME} />
</Layout>
