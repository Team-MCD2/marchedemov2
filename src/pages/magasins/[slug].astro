---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import NewsletterInline from "@components/NewsletterInline.astro";
import { MAGASINS, SITE, type MagasinSlug } from "@/lib/site";
import { FAQ_HOME } from "@/lib/faqs";
import { breadcrumbSchema, grocerySchema } from "@/lib/schema";

export function getStaticPaths() {
  return Object.values(MAGASINS).map((m) => ({ params: { slug: m.slug } }));
}

const { slug } = Astro.params as { slug: MagasinSlug };
const magasin = MAGASINS[slug];
if (!magasin) throw new Error(`Magasin non trouvé : ${slug}`);

const bc = breadcrumbSchema([
  { name: "Magasins", url: "/magasins" },
  { name: magasin.nom, url: `/magasins/${slug}` },
]);

const horairesList = [
  { label: "Lundi – Jeudi", value: magasin.horaires.lundiJeudi },
  { label: "Vendredi", value: magasin.horaires.vendredi },
  { label: "Samedi", value: magasin.horaires.samedi },
  { label: "Dimanche", value: magasin.horaires.dimanche },
];
---

<Layout
  title={`${magasin.nom} — ${magasin.adresseLigne1}, ${magasin.ville} · ${SITE.name}`}
  description={`Notre magasin ${magasin.nomCourt} : ${magasin.surface}, ${magasin.parking}, ouvert 7j/7. Boucherie halal, fruits & légumes exotiques, épices du monde.`}
  faqItems={FAQ_HOME}
  schema={[bc, grocerySchema(magasin)]}
>
  <Breadcrumb
    items={[
      { name: "Magasins", href: "/magasins" },
      { name: magasin.nomCourt },
    ]}
  />

  <!-- Hero -->
  <section class="bg-blanc pb-8">
    <div class="container-mo grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-7">
        <span class="eyebrow">Magasin</span>
        <h1 class="display-xl mt-4 text-balance">{magasin.nomCourt}</h1>
        <p class="mt-5 text-[17px] text-neutral-700">
          <strong>{magasin.adresseLigne1}</strong><br/>
          {magasin.codePostal} {magasin.ville}
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href={`tel:${magasin.telE164}`} class="btn btn-primary">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {magasin.telephone}
          </a>
          <a href={magasin.mapsLink} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            Itinéraire Google Maps
          </a>
        </div>

        <!-- Infos -->
        <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-6">
          <div>
            <p class="text-[12px] uppercase tracking-wider text-neutral-500 font-bold">Surface</p>
            <p class="font-soft font-bold text-[20px] mt-1">{magasin.surface}</p>
          </div>
          <div>
            <p class="text-[12px] uppercase tracking-wider text-neutral-500 font-bold">Parking</p>
            <p class="font-soft font-bold text-[20px] mt-1">{magasin.parking}</p>
          </div>
          <div>
            <p class="text-[12px] uppercase tracking-wider text-neutral-500 font-bold">Ouverture</p>
            <p class="font-soft font-bold text-[20px] mt-1">{magasin.dateOuverture}</p>
          </div>
          <div>
            <p class="text-[12px] uppercase tracking-wider text-neutral-500 font-bold">Ouvert</p>
            <p class="font-soft font-bold text-[20px] mt-1">7j/7</p>
          </div>
        </div>
      </div>

      <!-- Sidebar horaires -->
      <div class="lg:col-span-5">
        <div class="bg-creme rounded-3xl p-6 lg:p-8">
          <h2 class="font-soft font-bold text-[20px]">Horaires d'ouverture</h2>
          <ul class="mt-5 divide-y divide-black/10 text-[14.5px]">
            {horairesList.map((h) => (
              <li class="py-3 flex items-center justify-between gap-3">
                <span class="font-pro">{h.label}</span>
                <span class="font-bold text-right">{h.value}</span>
              </li>
            ))}
          </ul>
          <p class="mt-6 text-[12px] text-neutral-500 leading-relaxed">
            Horaires susceptibles d'évoluer les jours fériés — consultez notre page Facebook
            ou appelez-nous pour toute question.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Description + atouts -->
  <section class="section bg-blanc">
    <div class="container-mo grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-7">
        <h2 class="display-md text-balance">{magasin.accroche}</h2>
        <p class="mt-5 text-[15.5px] text-neutral-700 leading-relaxed">
          {magasin.description}
        </p>
      </div>
      <div class="lg:col-span-5">
        <div class="bg-creme rounded-3xl p-6">
          <p class="eyebrow">Nos atouts</p>
          <ul class="mt-4 space-y-3">
            {magasin.atouts.map((a) => (
              <li class="flex items-start gap-3 text-[14.5px]">
                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-vert shrink-0"></span>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Map embed (lazy iframe) -->
  <section class="section-sm bg-creme">
    <div class="container-mo">
      <p class="eyebrow">Nous trouver</p>
      <h2 class="display-md mt-4 text-balance">{magasin.adresseLigne1}, {magasin.ville}</h2>
      <div class="mt-8 aspect-[16/9] md:aspect-[21/9] rounded-3xl overflow-hidden ring-1 ring-black/10 bg-neutral-200">
        <iframe
          src={magasin.mapsEmbed}
          class="w-full h-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Carte ${magasin.nom}`}
        />
      </div>
    </div>
  </section>

  <NewsletterInline />
  <FAQAccordion items={FAQ_HOME} />
</Layout>
