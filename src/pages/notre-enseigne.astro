---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import Stats from "@components/Stats.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import NewsletterInline from "@components/NewsletterInline.astro";
import { SITE, MAGASINS } from "@/lib/site";
import { FAQ_HOME } from "@/lib/faqs";
import { breadcrumbSchema, organizationSchema } from "@/lib/schema";

const bc = breadcrumbSchema([{ name: "Notre enseigne", url: "/notre-enseigne" }]);

/* Timeline chronologique — dates réelles du parcours du groupe. */
const TIMELINE = [
  {
    date: "2022",
    label: "La naissance du projet",
    detail:
      "Samir Ouaddaha, issu d'une famille de commerçants, conçoit le Marché de Mo' comme un hommage à son père Mohammed — et un pari : faire entrer les saveurs du monde dans un supermarché grand public, à prix juste.",
  },
  {
    date: "Août 2024",
    label: "Ouverture Portet",
    detail:
      "Premier magasin — 1 200 m², 6 000 références le jour J, dans les anciens locaux de la Biocoop de Portet-sur-Garonne. Toulouse accueille son plus grand supermarché ethnique.",
  },
  {
    date: "2024",
    label: "Lauréat Réseau Entreprendre Occitanie",
    detail:
      "Distinction entrepreneuriale majeure. Parrainage par le directeur du magasin Auchan Gramont. Le projet est reconnu par l'écosystème économique régional.",
  },
  {
    date: "Avril 2026",
    label: "Ouverture Toulouse Sud — Cépière",
    detail:
      "Deuxième magasin, même surface, même philosophie. Centre commercial L'Hippodrome, sortie 27 de la rocade. L'enseigne passe de 1 à 2 adresses en 20 mois.",
  },
  {
    date: "2026",
    label: "15 nouveaux emplois",
    detail:
      "Plan de recrutement de 15 postes sur les 2 magasins — 12 CDI direct. Formation interne, grille salariale transparente, priorité à la motivation sur le diplôme.",
  },
] as const;

/* Les 3 piliers fondateurs du groupe — identité, pas slogan. */
const PILIERS = [
  {
    icon: "🎯",
    titre: "Qualité",
    detail:
      "Boucherie sur carcasse, fruits & légumes livrés chaque matin, épices importées en direct — pas de grossiste intermédiaire. La qualité n'est pas une option, c'est ce qui justifie le prix.",
  },
  {
    icon: "🤝",
    titre: "Engagement",
    detail:
      "Dons réguliers aux banques alimentaires de Haute-Garonne, soutien aux associations sportives locales, partenariats avec les structures pour personnes âgées. On rend à la ville ce qu'elle nous donne.",
  },
  {
    icon: "🌱",
    titre: "Inclusion",
    detail:
      "90 % de notre équipe n'avait pas d'emploi avant. 24 salariés entre 19 et 56 ans. Pas de diplôme exigé, pas de CV formel demandé — seule la motivation compte.",
  },
] as const;
---

<Layout
  title={`Notre enseigne — L'histoire du Marché de Mo' · ${SITE.name}`}
  description="Le Marché de Mo' est né d'une conviction : les saveurs du monde doivent être accessibles à tous. Retour sur notre histoire, notre équipe et notre ambition."
  faqItems={FAQ_HOME}
  schema={[bc, organizationSchema()]}
>
  <Breadcrumb items={[{ name: "Notre enseigne" }]} />

  <!-- HERO -->
  <section class="bg-blanc pb-8 relative overflow-hidden">
    <img src="/logos/favicon-marchedemo.png" alt="" aria-hidden="true" class="absolute -right-24 top-0 w-[620px] opacity-[0.04] pointer-events-none select-none" />
    <div class="container-mo relative">
      <span class="eyebrow">Notre histoire</span>
      <h1 class="display-xl mt-4 text-balance max-w-5xl">
        Une famille.<br/>
        Une <span class="text-vert">vision</span>.<br/>
        10 000+ références.
      </h1>
      <p class="mt-6 max-w-2xl text-[17px] text-neutral-600 leading-relaxed">
        Le Marché de Mo' est né en août 2024, à Portet-sur-Garonne, près de Toulouse.
        Depuis, <strong>10 000+ références</strong>, deux magasins et une équipe de
        <strong>24 passionnés</strong> racontent la même histoire : celle d'un
        commerçant indépendant, engagé, qui croit aux saveurs du monde.
      </p>
    </div>
  </section>

  <Stats />

  <!-- STORY -->
  <section class="section bg-blanc">
    <div class="container-mo grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-28">
        <div class="relative aspect-square rounded-[36px] overflow-hidden shadow-card bg-noir-softer reveal reveal-mask">
          <img
            src="/images/home/equipe.jpg"
            alt="L'équipe Marché de Mo' Toulouse"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
            width="800"
            height="800"
          />
        </div>
        <div class="mt-6 bg-creme rounded-2xl p-5">
          <p class="text-[13px] uppercase tracking-wider text-neutral-500 font-bold">Fondateur</p>
          <p class="font-soft font-bold text-[22px] mt-1">Samir Ouaddaha</p>
          <p class="text-[13.5px] text-neutral-600 mt-2">
            Lauréat 2024 · Réseau Entreprendre Occitanie · Parrainé par le
            directeur d'Auchan Gramont.
          </p>
        </div>
      </div>

      <div class="lg:col-span-7 space-y-10">
        <div>
          <span class="eyebrow">Chapitre 1 — Mo'</span>
          <h2 class="display-md mt-4">Mo', c'était <span class="text-vert">Mohammed</span>.</h2>
          <p class="mt-4 text-[15.5px] text-neutral-700 leading-relaxed">
            Le patriarche. Le père d'une famille de commerçants passionnés dont est
            issu Samir Ouaddaha. C'est en son hommage — et pour perpétuer cet esprit
            de transmission — que l'enseigne porte son nom.
          </p>
        </div>

        <div>
          <span class="eyebrow">Chapitre 2 — Portet</span>
          <h2 class="display-md mt-4">31 août 2024 : l'ouverture.</h2>
          <p class="mt-4 text-[15.5px] text-neutral-700 leading-relaxed">
            Le premier magasin ouvre ses portes au <strong>8 Allée Pablo Picasso</strong>,
            dans la zone commerciale de Portet-sur-Garonne, dans les locaux de
            l'ancienne Biocoop. 1 200 m², plus de 6 000 références le jour de l'ouverture,
            aujourd'hui 10 000+. Le plus grand supermarché ethnique d'Occitanie.
          </p>
        </div>

        <div>
          <span class="eyebrow">Chapitre 3 — Cépière</span>
          <h2 class="display-md mt-4">Un deuxième magasin, au cœur de Toulouse.</h2>
          <p class="mt-4 text-[15.5px] text-neutral-700 leading-relaxed">
            Le Groupe Marché de Mo' étend sa présence avec l'ouverture du magasin
            <strong>Toulouse Sud — Cépière</strong>, dans les locaux de l'ancien
            hypermarché du centre commercial L'Hippodrome. Même philosophie, même
            surface (1 200 m²), même engagement à recruter localement.
          </p>
        </div>

        <div>
          <span class="eyebrow">Chapitre 4 — Demain</span>
          <h2 class="display-md mt-4">Et après ?</h2>
          <p class="mt-4 text-[15.5px] text-neutral-700 leading-relaxed">
            D'autres magasins sont en projet. Mais avant l'expansion, notre priorité
            reste la même : <strong>qualité, engagement, inclusion</strong>. Chaque
            magasin est conçu pour être un lieu de lien social — pas juste un point
            de vente.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="section bg-creme">
    <div class="container-mo">
      <div class="max-w-2xl">
        <span class="eyebrow">Chronologie</span>
        <h2 class="display-md mt-4 text-balance">
          20 mois. <span class="text-vert">2 magasins.</span> Une trajectoire.
        </h2>
        <p class="mt-5 text-[15.5px] text-neutral-600 leading-relaxed">
          De l'idée à la deuxième ouverture, les dates qui ont construit le Groupe Marché de Mo'.
        </p>
      </div>

      <ol class="mt-14 relative pl-6 md:pl-0 md:max-w-3xl md:mx-auto">
        <span class="absolute left-2 md:left-1/2 md:-translate-x-1/2 top-2 bottom-2 w-[2px] bg-vert/25" aria-hidden="true"></span>
        {TIMELINE.map((t, i) => (
          <li
            class:list={[
              "relative mb-10 last:mb-0 md:grid md:grid-cols-2 md:gap-10 reveal",
              i % 2 === 0 ? "reveal-left" : "reveal-right",
            ]}
            style={`--reveal-delay: ${i * 80}ms`}
          >
            <span
              class="absolute left-2 md:left-1/2 md:-translate-x-1/2 top-2 w-3 h-3 rounded-full bg-vert ring-4 ring-creme shadow"
              aria-hidden="true"
            ></span>

            {i % 2 === 0 ? (
              <>
                <div class="md:text-right md:pr-10 pl-6 md:pl-0">
                  <p class="text-[13px] uppercase tracking-wider text-vert font-bold">{t.date}</p>
                  <h3 class="font-soft font-bold text-[22px] mt-1">{t.label}</h3>
                </div>
                <div class="mt-2 md:mt-0 md:pl-10 pl-6 md:border-l md:border-vert/20">
                  <p class="text-[15px] text-neutral-700 leading-relaxed">{t.detail}</p>
                </div>
              </>
            ) : (
              <>
                <div class="md:pr-10 md:text-right md:order-1 hidden md:block">
                  <p class="text-[15px] text-neutral-700 leading-relaxed">{t.detail}</p>
                </div>
                <div class="md:pl-10 md:order-2 pl-6">
                  <p class="text-[13px] uppercase tracking-wider text-vert font-bold">{t.date}</p>
                  <h3 class="font-soft font-bold text-[22px] mt-1">{t.label}</h3>
                  <p class="text-[15px] text-neutral-700 leading-relaxed mt-2 md:hidden">{t.detail}</p>
                </div>
              </>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- PILIERS — 3 valeurs fondatrices -->
  <section class="section bg-blanc">
    <div class="container-mo">
      <div class="max-w-2xl">
        <span class="eyebrow">Nos 3 piliers</span>
        <h2 class="display-md mt-4 text-balance">
          Notre ADN ne change pas. <span class="text-vert">Ni hier, ni demain.</span>
        </h2>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        {PILIERS.map((p, i) => (
          <article
            class="bg-creme rounded-3xl p-7 md:p-8 reveal transition-all hover:-translate-y-1 hover:shadow-card"
            style={`--reveal-delay: ${i * 90}ms`}
          >
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-white text-[26px]" aria-hidden="true">
              {p.icon}
            </span>
            <h3 class="font-soft font-bold text-[24px] mt-5">{p.titre}</h3>
            <p class="mt-3 text-[14.5px] text-neutral-700 leading-relaxed">{p.detail}</p>
          </article>
        ))}
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/nos-engagements" class="btn btn-secondary">
          Voir nos engagements en détail
        </a>
        <a href="/recrutement" class="text-[14px] font-bold text-vert hover:underline underline-offset-4">
          Nous rejoindre →
        </a>
      </div>
    </div>
  </section>

  <!-- CHIFFRES ENGAGEMENTS -->
  <section class="section bg-noir-section">
    <div class="container-mo">
      <span class="eyebrow !text-vert-light">En chiffres</span>
      <h2 class="display-lg mt-4 text-balance max-w-3xl !text-white">
        Le Marché de Mo', <span class="text-vert-light">c'est aussi</span> :
      </h2>

      <div class="mt-14 grid grid-cols-2 lg:grid-cols-4 gap-y-10 gap-x-6">
        <div><div class="stat-number !text-white">24</div><div class="mt-2 font-bold text-[14px] uppercase tracking-wide">salariés engagés</div></div>
        <div><div class="stat-number !text-white">90<span class="text-vert-light text-[0.7em]">%</span></div><div class="mt-2 font-bold text-[14px] uppercase tracking-wide">sans emploi avant</div></div>
        <div><div class="stat-number !text-white">120<span class="text-vert-light text-[0.7em]">+</span></div><div class="mt-2 font-bold text-[14px] uppercase tracking-wide">fruits exotiques</div></div>
        <div><div class="stat-number !text-white">19 – 56</div><div class="mt-2 font-bold text-[14px] uppercase tracking-wide">ans, notre équipe</div></div>
      </div>
    </div>
  </section>

  <!-- REJOINDRE L'ÉQUIPE -->
  <section class="section-sm bg-creme-warm">
    <div class="container-mo">
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <span class="eyebrow">Rejoindre l'équipe</span>
          <h2 class="display-md mt-4 text-balance">
            15 postes ouverts en 2026 <span class="text-vert">— pas de CV requis.</span>
          </h2>
          <p class="mt-5 text-[15.5px] text-neutral-700 leading-relaxed max-w-2xl">
            Boucher·e halal, conseiller·e rayon, chauffeur-livreur, responsable de rayon.
            12 postes en <strong>CDI direct</strong>, formation interne accompagnée,
            grille salariale transparente, tickets restaurant et mutuelle prise en
            charge à 80 %.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/recrutement" class="btn btn-primary">Voir les offres ouvertes</a>
            <a href="/actualites/recrutement-2026-15-postes" class="btn btn-secondary">
              Lire les détails des 15 postes
            </a>
          </div>
        </div>
        <div class="lg:col-span-4 hidden lg:block">
          <div class="aspect-square rounded-[32px] overflow-hidden shadow-card bg-noir-softer reveal reveal-mask">
            <img
              src="/images/rayons/saveur-mediterranee/ouvrier-d-x27-epicerie.jpg"
              alt="Employé d'épicerie Marché de Mo'"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MAGASINS teaser -->
  <section class="section bg-blanc">
    <div class="container-mo">
      <span class="eyebrow">Nos magasins</span>
      <h2 class="display-md mt-4 max-w-3xl">Venez nous rencontrer.</h2>
      <div class="mt-10 grid md:grid-cols-2 gap-6">
        {Object.values(MAGASINS).map((m) => (
          <a href={`/magasins/${m.slug}`} class="group bg-creme rounded-3xl p-6 md:p-8 hover:bg-creme-warm transition-all duration-300 hover:-translate-y-1">
            <span class="pill pill-vert">{m.badge}</span>
            <h3 class="font-soft font-bold text-[24px] mt-4">{m.nomCourt}</h3>
            <p class="text-[14px] text-neutral-600 mt-2">{m.adresseLigne1}, {m.codePostal} {m.ville}</p>
            <span class="mt-5 inline-flex items-center gap-2 font-bold text-[14px] text-vert group-hover:translate-x-1 transition-transform">Voir le magasin →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <NewsletterInline />
  <FAQAccordion items={FAQ_HOME} />
</Layout>
