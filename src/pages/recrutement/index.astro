---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import NewsletterInline from "@components/NewsletterInline.astro";
import ApplicationForm from "@components/islands/ApplicationForm.jsx";
import { getCollection } from "astro:content";
import { SITE } from "@/lib/site";
import { FAQ_RECRUTEMENT } from "@/lib/faqs";
import { breadcrumbSchema } from "@/lib/schema";

const postes = (await getCollection("postes", (p) => p.data.actif))
  .sort((a, b) =>
    new Date(b.data.date_publication).getTime() - new Date(a.data.date_publication).getTime()
  );

const bc = breadcrumbSchema([{ name: "Recrutement", url: "/recrutement" }]);
---

<Layout
  title={`Rejoindre l'équipe — ${postes.length} postes ouverts · ${SITE.name}`}
  description="Nous recrutons toute l'année. Boucherie halal, employé polyvalent, alternance B2B, apprentissage. 90% de notre équipe n'avait pas d'emploi avant le Marché de Mo'."
  faqItems={FAQ_RECRUTEMENT}
  schema={bc}
>
  <Breadcrumb items={[{ name: "Recrutement" }]} />

  <!-- Hero -->
  <section class="bg-noir-section text-white pb-14 relative overflow-hidden">
    <img src="/logos/favicon-marchedemo-contourwh.png" alt="" aria-hidden="true" class="absolute -right-20 top-0 w-[600px] opacity-[0.06] pointer-events-none select-none" />
    <div class="container-mo relative z-10 py-14">
      <span class="eyebrow !text-vert-light">Rejoignez-nous</span>
      <h1 class="display-xl mt-4 text-balance max-w-4xl !text-white">
        Pas de diplôme ?<br/>
        Pas d'expérience ?<br/>
        <span class="text-vert-light">Ce n'est pas un problème.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-[17px] text-white/80 leading-relaxed">
        <strong class="text-white">90% de notre équipe</strong> n'avait pas d'emploi avant de
        rejoindre le Marché de Mo'. Nous recrutons <strong class="text-white">entre 19 et 56 ans</strong>,
        sur la motivation et le sens du service. Le reste, on vous l'apprend.
      </p>
    </div>
  </section>

  <!-- Liste postes -->
  <section class="section bg-blanc">
    <div class="container-mo">
      <span class="eyebrow">Offres ouvertes</span>
      <h2 class="display-md mt-4 text-balance max-w-2xl">
        {postes.length} postes ouverts — <span class="text-vert">et ça continue</span>.
      </h2>

      <ul class="mt-10 divide-y divide-black/10">
        {postes.map((p) => (
          <li>
            <a
              href={`/recrutement/${p.slug}`}
              class="group py-6 md:py-7 flex flex-col md:flex-row md:items-center gap-4 md:gap-6 hover:bg-creme -mx-4 md:-mx-6 px-4 md:px-6 rounded-2xl transition-colors"
            >
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-2">
                  <span class="pill pill-vert">{p.data.type_contrat}</span>
                  <span class="pill bg-white border border-black/10 text-neutral-600">{p.data.temps}</span>
                  <span class="pill bg-white border border-black/10 text-neutral-600">
                    {p.data.magasin === "tous" ? "Les 2 magasins" :
                      p.data.magasin === "portet" ? "Portet" : "Toulouse Sud"}
                  </span>
                </div>
                <h3 class="font-soft font-bold text-[22px] md:text-[26px] leading-tight">
                  {p.data.titre}
                </h3>
                <p class="mt-1.5 text-[14.5px] text-neutral-600 max-w-2xl">{p.data.resume}</p>
              </div>
              <span class="shrink-0 inline-flex items-center gap-2 font-bold text-[14px] text-vert group-hover:translate-x-1 transition-transform">
                Voir le poste
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Spontanée -->
  <section class="section bg-creme">
    <div class="container-mo grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-5">
        <span class="eyebrow">Candidature spontanée</span>
        <h2 class="display-md mt-4 text-balance">Aucune offre ne vous correspond ?</h2>
        <p class="mt-5 text-[15.5px] text-neutral-700 leading-relaxed">
          Aucun souci — nous recrutons en permanence. Envoyez-nous votre candidature
          spontanée, nous la regarderons avec attention et reviendrons vers vous
          sous 48h ouvrées.
        </p>
        <div class="mt-8 bg-white rounded-2xl p-5 border-l-4 border-vert">
          <p class="text-[14px] text-neutral-700">
            <strong>Vous préférez le contact direct ?</strong><br/>
            Passez nous voir à Portet tous les mercredis après-midi, sans rendez-vous.
          </p>
        </div>
      </div>
      <div class="lg:col-span-7">
        <ApplicationForm client:visible poste="spontanee" posteNom="Candidature spontanée" />
      </div>
    </div>
  </section>

  <NewsletterInline />
  <FAQAccordion items={FAQ_RECRUTEMENT} />
</Layout>
