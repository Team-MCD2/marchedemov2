---
export const prerender = false;

import Layout from "@layouts/Layout.astro";
import AdminTopbar from "@components/admin/AdminTopbar.astro";
import StatCard from "@components/admin/StatCard.astro";
import QuickAction from "@components/admin/QuickAction.astro";
import ActivityFeed from "@components/admin/ActivityFeed.astro";
import Sparkline from "@components/admin/Sparkline.astro";
import { SITE } from "@/lib/site";
import { isAuthenticated } from "@/lib/auth";
import { supabaseAdmin } from "@/lib/supabase";
import {
  recentActivity,
  activityTableStatus,
  dailyActivityCounts,
} from "@/lib/admin-activity";
import { getCollection } from "astro:content";

if (!(await isAuthenticated(Astro.cookies))) {
  return Astro.redirect("/admin/login");
}

/* ----------------------------------------------------------------- */
/* Counts + 7-day deltas                                              */
/* ----------------------------------------------------------------- */

const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();

async function safeCount(
  table: "promos" | "produits",
  filter?: (q: any) => any,
): Promise<number> {
  if (!supabaseAdmin) return 0;
  let q: any = supabaseAdmin.from(table).select("id", { count: "exact", head: true });
  if (filter) q = filter(q);
  const { count, error } = await q;
  if (error) return 0;
  return count ?? 0;
}

const [
  promosTotal,
  promosActives,
  promosNew7d,
  produitsTotal,
  produitsActifs,
  produitsNew7d,
  produitsSansImage,
] = await Promise.all([
  safeCount("promos"),
  safeCount("promos", (q) => q.eq("actif", true)),
  safeCount("promos", (q) => q.gte("created_at", sevenDaysAgo)),
  safeCount("produits"),
  safeCount("produits", (q) => q.eq("actif", true)),
  safeCount("produits", (q) => q.gte("created_at", sevenDaysAgo)),
  safeCount("produits", (q) => q.is("image_url", null)),
]);

/* Activity rows : 20 most recent, plus a standalone count for the
 * "Activité 7 j" stat card. recentActivity() degrades to [] gracefully
 * when migration 002 hasn't been run yet.
 *
 * We also probe the table availability explicitly so we can tell the
 * difference between "migration not applied" (= show the banner) and
 * "table is there but empty" (= show the normal empty hint). */
const activityStatus = await activityTableStatus();
const activityRows = activityStatus.available ? await recentActivity(20) : [];
const activity7d = activityRows.filter((r) => r.created_at >= sevenDaysAgo).length;

/* 14-day sparklines fed straight from the audit log. Returns null
 * when the migration hasn't been applied — callers hide the
 * sparkline section entirely in that case so we don't show
 * misleading flat-zero lines. */
const dailyBuckets = activityStatus.available ? await dailyActivityCounts(14) : null;
const dayLabelFmt = new Intl.DateTimeFormat("fr-FR", {
  weekday: "short",
  day: "2-digit",
  month: "short",
});
const sparkLabels = (dailyBuckets ?? []).map((b) =>
  dayLabelFmt.format(new Date(`${b.date}T00:00:00Z`))
);
const produitsDaily = (dailyBuckets ?? []).map((b) => b.byEntity.produit);
const promosDaily = (dailyBuckets ?? []).map((b) => b.byEntity.promo);
const totalDaily = (dailyBuckets ?? []).map((b) => b.total);
const produits14d = produitsDaily.reduce((a, b) => a + b, 0);
const promos14d = promosDaily.reduce((a, b) => a + b, 0);
const total14d = totalDaily.reduce((a, b) => a + b, 0);

/* Recent promos for the right-hand panel — Supabase first, content
 * collection fallback if DB unreachable. */
let recentPromos: any[] = [];
let promosError: string | null = null;
if (supabaseAdmin) {
  const { data, error } = await supabaseAdmin
    .from("promos")
    .select("id, actif, titre, reduction_pct, magasin, rayon, updated_at")
    .order("updated_at", { ascending: false })
    .limit(5);
  if (error) {
    promosError = error.message;
  } else {
    recentPromos = data ?? [];
  }
}
if (recentPromos.length === 0) {
  const fallback = await getCollection("promos");
  recentPromos = fallback
    .map((p) => ({ ...p.data, id: p.id }))
    .slice(0, 5);
}

/* Last 5 modified produits — useful for owners reviewing what just shipped. */
let recentProduits: any[] = [];
if (supabaseAdmin) {
  const { data } = await supabaseAdmin
    .from("produits")
    .select("id, nom, slug, rayon, actif, image_url, updated_at")
    .order("updated_at", { ascending: false })
    .limit(5);
  recentProduits = data ?? [];
}

/* Static collections for the lower workflow note. */
const postes   = await getCollection("postes");
const articles = await getCollection("articles");
const activePostes   = postes.filter((p) => p.data.actif).length;
const activeArticles = articles.filter((a) => a.data.actif).length;

const isOnline = !!supabaseAdmin && !promosError;
---

<Layout
  title={`Tableau de bord · ${SITE.name} — Admin`}
  description="Tableau de bord d'administration du site."
  noIndex
  hideChrome
>
  <div class="min-h-screen bg-creme">
    <AdminTopbar current="dashboard" subtitle="Tableau de bord" />

    <main class="container-mo py-6 md:py-10">
      <!-- Hero -->
      <section class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 mb-6 md:mb-8">
        <div>
          <span class="eyebrow">Tableau de bord</span>
          <h1 class="font-soft font-bold text-[26px] md:text-[32px] leading-tight mt-2">
            Bienvenue.
          </h1>
          <p class="mt-1.5 text-[13px] md:text-[14px] text-neutral-500 max-w-xl">
            Une vue d'ensemble de l'activité du site. Tous les chiffres sont en temps réel.
          </p>
        </div>
        <div class="flex items-center gap-3 text-[12.5px] text-neutral-500 shrink-0">
          {isOnline ? (
            <span class="inline-flex items-center gap-2 bg-vert/10 text-vert-dark px-3 py-1.5 rounded-full font-bold">
              <span class="w-1.5 h-1.5 rounded-full bg-vert animate-pulse"></span>
              Supabase connecté
            </span>
          ) : (
            <span class="inline-flex items-center gap-2 bg-rouge/10 text-rouge px-3 py-1.5 rounded-full font-bold">
              <span class="w-1.5 h-1.5 rounded-full bg-rouge"></span>
              {supabaseAdmin ? "Supabase erreur" : "Supabase non configuré"}
            </span>
          )}
        </div>
      </section>

      {!activityStatus.available && activityStatus.reason === "missing" && (
        <section
          class="mb-6 bg-orange-50 border border-orange-200 rounded-2xl p-4 md:p-5 flex flex-col md:flex-row md:items-start gap-3 md:gap-4"
          data-admin-banner="activity-missing"
        >
          <div class="shrink-0 w-9 h-9 rounded-full bg-orange-100 text-orange-700 text-[18px] flex items-center justify-center">⚠</div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-[14px] text-orange-900">Table <code class="bg-orange-100 text-orange-900 px-1.5 py-0.5 rounded">admin_activity</code> absente</p>
            <p class="text-[12.5px] text-orange-800 mt-1">
              Le flux d'activité et les cartes « Activité 7j » resteront vides tant que la migration
              <code class="bg-orange-100 text-orange-900 px-1.5 py-0.5 rounded text-[12px]">supabase/migrations/002_admin_activity.sql</code>
              n'est pas appliquée. Ouvrez Supabase Studio → SQL Editor → collez le fichier → Run.
            </p>
            <div class="mt-3 flex flex-wrap items-center gap-2">
              <button
                type="button"
                data-activity-copy
                class="inline-flex items-center gap-1.5 text-[12px] font-bold bg-orange-900 text-white hover:bg-orange-800 px-3 py-1.5 rounded-full transition"
              >
                <span data-activity-copy-label>Copier le chemin du fichier</span>
              </button>
              <a
                href="https://supabase.com/dashboard"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-[12px] font-bold text-orange-900 hover:underline"
              >
                Ouvrir Supabase Studio ↗
              </a>
            </div>
          </div>
        </section>
      )}

      {!activityStatus.available && activityStatus.reason === "unknown" && (
        <section
          class="mb-6 bg-rouge/5 border border-rouge/20 rounded-2xl p-4 md:p-5"
          data-admin-banner="activity-error"
        >
          <p class="font-bold text-[13px] text-rouge">Audit trail indisponible</p>
          <p class="text-[12.5px] text-neutral-700 mt-1">
            La table <code class="bg-rouge/10 px-1.5 py-0.5 rounded text-[12px]">admin_activity</code> existe mais n'a pas pu être lue
            {activityStatus.detail ? <> : <em>{activityStatus.detail}</em></> : null}.
            Les écritures continuent de fonctionner, seule la traçabilité est masquée.
          </p>
        </section>
      )}

      <!-- Stat cards -->
      <section class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
        <StatCard
          label="Promos actives"
          value={promosActives}
          total={promosTotal}
          delta={promosNew7d}
          deltaSuffix="nouvelles 7j"
          href="/admin/promos"
          tone="rouge"
          icon="🏷"
          hint={promosTotal === 0 ? "Aucune promo en base" : undefined}
        />
        <StatCard
          label="Produits actifs"
          value={produitsActifs}
          total={produitsTotal}
          delta={produitsNew7d}
          deltaSuffix="nouveaux 7j"
          href="/admin/catalogue"
          tone="vert"
          icon="🛒"
          hint={produitsTotal === 0 ? "Aucun produit en base" : undefined}
        />
        <StatCard
          label="Sans image"
          value={produitsSansImage}
          total={produitsTotal}
          href="/admin/images-gap"
          tone="orange"
          icon="🖼"
          hint={
            produitsTotal === 0
              ? undefined
              : `${
                  produitsTotal > 0
                    ? Math.round((produitsSansImage / produitsTotal) * 100)
                    : 0
                } % du catalogue`
          }
        />
        <StatCard
          label="Activité 7j"
          value={activity7d}
          delta={activity7d}
          deltaSuffix="actions"
          tone="noir"
          icon="📜"
          hint={activityRows.length === 0 ? "Migration 002 à appliquer" : "Écritures admin"}
        />
      </section>

      {dailyBuckets && total14d > 0 && (
        <section class="mt-6 md:mt-8">
          <div class="flex items-center justify-between mb-3">
            <h2 class="eyebrow">Activité 14 jours</h2>
            <span class="text-[11.5px] text-neutral-400">
              Source : audit trail · {total14d} actions
            </span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <div class="bg-white rounded-3xl p-4 md:p-5 shadow-card flex items-center gap-4">
              <div class="flex-1 min-w-0">
                <p class="text-[11px] uppercase tracking-wider font-bold text-neutral-400">Produits</p>
                <p class="font-soft font-bold text-[24px] leading-tight mt-1">{produits14d}</p>
                <p class="text-[11.5px] text-neutral-500">écritures sur 14 j</p>
              </div>
              <div class="text-vert-dark shrink-0">
                <Sparkline
                  values={produitsDaily}
                  labels={sparkLabels}
                  ariaLabel="Activité produits 14 jours"
                  width={120}
                  height={36}
                />
              </div>
            </div>
            <div class="bg-white rounded-3xl p-4 md:p-5 shadow-card flex items-center gap-4">
              <div class="flex-1 min-w-0">
                <p class="text-[11px] uppercase tracking-wider font-bold text-neutral-400">Promos</p>
                <p class="font-soft font-bold text-[24px] leading-tight mt-1">{promos14d}</p>
                <p class="text-[11.5px] text-neutral-500">écritures sur 14 j</p>
              </div>
              <div class="text-rouge shrink-0">
                <Sparkline
                  values={promosDaily}
                  labels={sparkLabels}
                  ariaLabel="Activité promos 14 jours"
                  width={120}
                  height={36}
                />
              </div>
            </div>
            <div class="bg-white rounded-3xl p-4 md:p-5 shadow-card flex items-center gap-4">
              <div class="flex-1 min-w-0">
                <p class="text-[11px] uppercase tracking-wider font-bold text-neutral-400">Toutes entités</p>
                <p class="font-soft font-bold text-[24px] leading-tight mt-1">{total14d}</p>
                <p class="text-[11.5px] text-neutral-500">écritures sur 14 j</p>
              </div>
              <div class="text-noir shrink-0">
                <Sparkline
                  values={totalDaily}
                  labels={sparkLabels}
                  ariaLabel="Activité totale 14 jours"
                  width={120}
                  height={36}
                />
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- Quick actions strip -->
      <section class="mt-6 md:mt-8">
        <div class="flex items-center justify-between mb-3">
          <h2 class="eyebrow">Actions rapides</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-3">
          <QuickAction
            href="/admin/promos#new"
            icon="➕"
            label="Nouvelle promo"
            sublabel="Crée + applique"
            tone="rouge"
          />
          <QuickAction
            href="/admin/produits#new"
            icon="➕"
            label="Nouveau produit"
            sublabel="Catalogue Supabase"
            tone="vert"
          />
          <QuickAction
            href="/admin/medias"
            icon="📤"
            label="Uploader des images"
            sublabel="Drag & drop"
            tone="orange"
          />
          <QuickAction
            href="/admin/produits#import"
            icon="📥"
            label="Importer CSV / JSON"
            sublabel="Mise à jour de masse"
            tone="noir"
          />
          <QuickAction
            href="/admin/catalogue"
            icon="🌳"
            label="Naviguer le catalogue"
            sublabel="Par rayon → catégorie"
            tone="vert"
          />
        </div>
      </section>

      <!-- Two-column : recent activity + recent items -->
      <section class="mt-6 md:mt-8 grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-5">
        <!-- Activity feed -->
        <div class="bg-white rounded-3xl p-5 md:p-6 shadow-card">
          <div class="flex items-center justify-between mb-2">
            <div>
              <h2 class="eyebrow">Activité récente</h2>
              <p class="text-[12px] text-neutral-500 mt-0.5">
                Toutes les écritures admin, ordre antéchronologique.
              </p>
            </div>
            {activityRows.length > 0 && (
              <span class="text-[11px] text-neutral-400 tabular-nums">{activityRows.length} entrée(s)</span>
            )}
          </div>
          <ActivityFeed
            rows={activityRows}
            emptyHint="Appliquez supabase/migrations/002_admin_activity.sql, puis effectuez une écriture pour voir le flux."
          />
        </div>

        <!-- Recent items column -->
        <div class="grid grid-cols-1 gap-5">
          <!-- Recent promos -->
          <div class="bg-white rounded-3xl p-5 md:p-6 shadow-card">
            <div class="flex items-center justify-between">
              <h3 class="eyebrow">Promos modifiées</h3>
              <a href="/admin/promos" class="text-[11px] text-vert font-bold hover:underline">Gérer →</a>
            </div>
            {recentPromos.length === 0 ? (
              <p class="mt-4 text-[12px] text-neutral-400">Aucune promo en base.</p>
            ) : (
              <ul class="mt-3 divide-y divide-black/5">
                {recentPromos.map((p) => (
                  <li class="py-2.5 flex items-center justify-between gap-3 min-w-0">
                    <div class="min-w-0 flex-1">
                      <p class="font-bold text-[13px] truncate">{p.titre}</p>
                      <p class="text-[11px] text-neutral-500 truncate">
                        −{p.reduction_pct}% · {p.magasin ?? "tous"}
                      </p>
                    </div>
                    <span
                      class:list={[
                        "px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider shrink-0",
                        p.actif ? "bg-vert/10 text-vert-dark" : "bg-neutral-100 text-neutral-500",
                      ]}
                    >
                      {p.actif ? "Actif" : "Inactif"}
                    </span>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <!-- Recent produits -->
          <div class="bg-white rounded-3xl p-5 md:p-6 shadow-card">
            <div class="flex items-center justify-between">
              <h3 class="eyebrow">Produits modifiés</h3>
              <a href="/admin/produits" class="text-[11px] text-vert font-bold hover:underline">Gérer →</a>
            </div>
            {recentProduits.length === 0 ? (
              <p class="mt-4 text-[12px] text-neutral-400">Aucun produit modifié récemment.</p>
            ) : (
              <ul class="mt-3 divide-y divide-black/5">
                {recentProduits.map((p) => (
                  <li class="py-2.5 flex items-center justify-between gap-3 min-w-0">
                    <div class="min-w-0 flex-1">
                      <p class="font-bold text-[13px] truncate">{p.nom}</p>
                      <p class="text-[11px] text-neutral-500 truncate">{p.rayon}</p>
                    </div>
                    {!p.image_url ? (
                      <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-orange-100 text-orange-700 shrink-0">
                        Sans image
                      </span>
                    ) : !p.actif ? (
                      <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-neutral-100 text-neutral-500 shrink-0">
                        Inactif
                      </span>
                    ) : (
                      <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-vert/10 text-vert-dark shrink-0">
                        OK
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </section>

      <!-- Workflow note -->
      <section class="mt-6 md:mt-8 bg-white rounded-3xl p-5 md:p-6 shadow-card">
        <h2 class="eyebrow">Comment gérer le contenu</h2>
        <div class="mt-3 grid md:grid-cols-2 gap-5 text-[13px] text-neutral-700 leading-relaxed">
          <div>
            <p class="font-bold text-noir mb-1.5">✓ Via l'admin (temps réel)</p>
            <ul class="space-y-1 text-[12.5px]">
              <li>• <strong>Promos</strong> → <a href="/admin/promos" class="text-vert hover:underline">/admin/promos</a> — table Supabase, modifs instantanées.</li>
              <li>• <strong>Produits</strong> → <a href="/admin/catalogue" class="text-vert hover:underline">/admin/catalogue</a> — drill-down par rayon.</li>
              <li>• <strong>Images</strong> → <a href="/admin/medias" class="text-vert hover:underline">/admin/medias</a> — Supabase Storage.</li>
            </ul>
          </div>
          <div>
            <p class="font-bold text-noir mb-1.5">✎ Via Git (déploiement)</p>
            <ul class="space-y-1 text-[12.5px]">
              <li>• <strong>Offres d'emploi</strong> ({activePostes}/{postes.length}) : <code class="bg-creme px-1.5 py-0.5 rounded text-[12px]">src/content/postes/*.md</code></li>
              <li>• <strong>Vidéos TikTok</strong> : <code class="bg-creme px-1.5 py-0.5 rounded text-[12px]">src/content/videos/*.json</code></li>
              <li>• <strong>Articles blog</strong> ({activeArticles}/{articles.length}) : <code class="bg-creme px-1.5 py-0.5 rounded text-[12px]">src/content/articles/*.md</code></li>
            </ul>
          </div>
        </div>
        {promosError && (
          <p class="mt-4 text-[12px] text-rouge bg-rouge/5 px-3 py-2 rounded-xl">
            ⚠ Supabase erreur : {promosError} — fallback sur Content Collections.
          </p>
        )}
      </section>
    </main>
  </div>
</Layout>

<script>
  /* Small inline UX for the activity-missing banner : copy the migration
   * path so the owner can paste it in their editor / terminal and grab
   * the SQL quickly. Fails silently on browsers without clipboard API. */
  (() => {
    const btn = document.querySelector("[data-activity-copy]");
    if (!(btn instanceof HTMLElement)) return;
    const label = btn.querySelector("[data-activity-copy-label]");
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("supabase/migrations/002_admin_activity.sql");
        if (label instanceof HTMLElement) {
          const prev = label.textContent;
          label.textContent = "✓ Copié";
          setTimeout(() => {
            label.textContent = prev ?? "Copier le chemin du fichier";
          }, 1800);
        }
      } catch {
        if (label instanceof HTMLElement) {
          label.textContent = "✗ Impossible de copier";
        }
      }
    });
  })();
</script>
