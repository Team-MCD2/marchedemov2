---
/**
 * Layout.astro — wrap every page.
 * Injects: Typekit (Filson Pro/Soft), full SEO head, sticky Header, full Footer.
 * Each page passes its own title/description/og/faq/schema via Astro.props.
 */
import "@styles/global.css";
import { ViewTransitions } from "astro:transitions";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import TickerBanner from "@components/TickerBanner.astro";
import ChatMo from "@components/islands/ChatMo.jsx";
import { SITE } from "@/lib/site";
import { faqSchema } from "@/lib/schema";
import type { FAQItem } from "@/lib/faqs";

interface Props {
  /** Page title (used as <title> and og:title). */
  title: string;
  /** Meta description + og:description. 150–160 chars max. */
  description: string;
  /** Canonical URL. If omitted, we'll derive it. */
  canonical?: string;
  /** Image for social sharing (path from root or absolute). */
  ogImage?: string;
  /** Hero image to preload for LCP (absolute path starting with /). */
  heroImage?: string;
  /** Type hint for hero image preload (e.g. "image/webp", "image/jpeg"). */
  heroImageType?: string;
  /** Accordion FAQ items. If provided, injects FAQPage JSON-LD automatically. */
  faqItems?: FAQItem[];
  /** Extra schema.org objects (Organization, GroceryStore, Offer, etc.). */
  schema?: object | object[];
  /** Lock body scroll (e.g. for /admin login screens). */
  noIndex?: boolean;
  /** Extra body classes (rayons culturels : `data-rayon` + bg). */
  bodyClass?: string;
  bodyDataRayon?: string;
  /** Hide header/footer (for minimal admin screens). */
  hideChrome?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = "/logos/logo-marchedemo-rond-contourgreen.png",
  heroImage,
  heroImageType,
  faqItems,
  schema,
  noIndex,
  bodyClass = "",
  bodyDataRayon,
  hideChrome,
} = Astro.props as Props;

function inferImageType(path?: string): string | undefined {
  if (!path) return undefined;
  const ext = path.split("?")[0].split(".").pop()?.toLowerCase();
  if (ext === "jpg" || ext === "jpeg") return "image/jpeg";
  if (ext === "png") return "image/png";
  if (ext === "webp") return "image/webp";
  if (ext === "avif") return "image/avif";
  return undefined;
}
const heroType = heroImageType ?? inferImageType(heroImage);

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const absoluteOgImage = ogImage.startsWith("http") ? ogImage : `${SITE.url}${ogImage}`;
const schemas = Array.isArray(schema) ? schema : schema ? [schema] : [];
---

<!doctype html>
<html lang="fr" data-astro-cid>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicon officiel : portrait sketch de Mo' -->
    <link rel="icon" type="image/png" href="/logos/favicon-marchedemo.png" />
    <link rel="apple-touch-icon" href="/logos/logo-marchedemo-rond-contourgreen.png" />
    <meta name="theme-color" content="#1C6B35" />

    <!-- Typekit : Filson Pro + Filson Soft -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="preconnect" href="https://p.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/tci0qgy.css" />

    <!-- Preload du logo du header pour le premier paint -->
    <link
      rel="preload"
      as="image"
      href="/logos/logo-marchedemo-rond-contourgreen.png"
      type="image/png"
      fetchpriority="high"
    />

    {heroImage && (
      <link
        rel="preload"
        as="image"
        href={heroImage}
        type={heroType}
        fetchpriority="high"
      />
    )}

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="author" content={SITE.name} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- JSON-LD : FAQ (auto si faqItems) -->
    {faqItems && faqItems.length > 0 && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(faqSchema(faqItems))}
      />
    )}

    <!-- JSON-LD : autres schémas -->
    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Astro View Transitions : fondu inter-pages + SPA-like navigation -->
    <ViewTransitions />
  </head>

  <body
    class={`min-h-screen flex flex-col bg-white text-[color:var(--color-texte)] font-pro antialiased ${bodyClass}`}
    data-rayon={bodyDataRayon}
  >
    {/* Scroll progress bar — always at the very top of viewport.
        Width driven by `--scroll-progress` CSS variable updated from scroll handler. */}
    <div class="scroll-progress" aria-hidden="true"></div>

    {!hideChrome && (
      <>
        <TickerBanner />
        <Header />
      </>
    )}

    <main class="flex-1">
      <slot />
    </main>

    {!hideChrome && <Footer />}

    {!hideChrome && (
      <ChatMo
        client:idle
        phoneE164={SITE.phoneE164}
        phoneDisplay={SITE.phone}
        email={SITE.email}
      />
    )}

    <!--
      Scroll-reveal observer — ajoute .is-visible aux éléments .reveal
      quand ils entrent dans le viewport. Re-déclenché après chaque
      ViewTransition via astro:page-load.
      Respecte prefers-reduced-motion (CSS force les éléments visibles).

      Features :
        • Support .reveal / .reveal-left / .reveal-right / .reveal-scale / .reveal-blur
        • data-reveal-delay="200" → override manual delay (ms)
        • [data-reveal-stagger] parent → children get auto-incrementing delays
          (step from data-reveal-step or default 80ms, capped at 600ms)
        • Respecte prefers-reduced-motion (skip observer entirely)
    -->
    <script is:inline>
      (function () {
        const prefersReduced =
          window.matchMedia &&
          window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        const applyStagger = (parent) => {
          const step = Number(parent.dataset.revealStep || 80);
          const cap  = Number(parent.dataset.revealCap  || 600);
          const kids = parent.querySelectorAll(":scope > .reveal, :scope > * > .reveal");
          kids.forEach((kid, i) => {
            if (kid.dataset.revealDelay) return; /* manual override respected */
            const d = Math.min(i * step, cap);
            kid.style.setProperty("--reveal-delay", d + "ms");
          });
        };

        const mount = () => {
          /* Apply stagger delays on [data-reveal-stagger] parents. */
          document.querySelectorAll("[data-reveal-stagger]").forEach(applyStagger);

          /* Manual delays from data-reveal-delay. */
          document
            .querySelectorAll(".reveal[data-reveal-delay]:not(.is-visible)")
            .forEach((el) => {
              el.style.setProperty("--reveal-delay", el.dataset.revealDelay + "ms");
            });

          if (prefersReduced) {
            document
              .querySelectorAll(".reveal:not(.is-visible)")
              .forEach((el) => el.classList.add("is-visible"));
            return;
          }

          const els = document.querySelectorAll(".reveal:not(.is-visible)");
          if (!els.length || !("IntersectionObserver" in window)) {
            els.forEach((el) => el.classList.add("is-visible"));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  io.unobserve(entry.target);
                }
              });
            },
            { rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
          );
          els.forEach((el) => io.observe(el));
        };

        document.addEventListener("astro:page-load", mount);
        if (document.readyState !== "loading") mount();
        else document.addEventListener("DOMContentLoaded", mount);
      })();
    </script>

    <!--
      Animations FULL — parallax / tilt / split-reveal / scroll progress.
      All features opt-in via data attributes, zero impact on markup
      that doesn't use them. Single rAF loop for scroll-linked effects
      to avoid perf hit. Respect prefers-reduced-motion.

      Usage :
        [data-parallax="0.3"]    → translate Y proportional to scroll progress
                                    (0.3 = slow, 0.6 = faster, negative = reversed)
        [data-tilt]              → 3D tilt on mouse move (desktop only)
        [data-tilt-max="8"]      → max rotation angle (default 6deg)
        [data-split-reveal]      → split children in words, fade+rise each
                                    with stagger delay on entry
    -->
    <script is:inline>
      (function () {
        const prefersReduced =
          window.matchMedia &&
          window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        /* ---------------------- SCROLL PROGRESS BAR ---------------------- */
        const progressEl = document.querySelector(".scroll-progress");
        const onScrollProgress = () => {
          if (!progressEl) return;
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          const p = max > 0 ? (h.scrollTop / max) * 100 : 0;
          progressEl.style.setProperty("--scroll-progress", p + "%");
        };

        /* ---------------------- PARALLAX (scroll-linked) ---------------------- */
        /* Single rAF tick updates all [data-parallax] elements based on
           their viewport position. `speed` in (-1, 1), typically 0.2 - 0.5. */
        let parallaxEls = [];
        const collectParallax = () => {
          parallaxEls = Array.from(document.querySelectorAll("[data-parallax]")).map((el) => ({
            el,
            speed: parseFloat(el.dataset.parallax) || 0.3,
          }));
        };
        const updateParallax = () => {
          if (prefersReduced) return;
          const wH = window.innerHeight;
          parallaxEls.forEach(({ el, speed }) => {
            const rect = el.getBoundingClientRect();
            const elCenter = rect.top + rect.height / 2;
            const viewCenter = wH / 2;
            /* Delta from viewport center in px. Further away = more offset. */
            const delta = elCenter - viewCenter;
            el.style.setProperty("--parallax-y", (delta * speed * -0.3).toFixed(1) + "px");
          });
        };

        /* Throttled rAF for scroll-linked effects */
        let rafScheduled = false;
        const onScrollFrame = () => {
          if (rafScheduled) return;
          rafScheduled = true;
          requestAnimationFrame(() => {
            onScrollProgress();
            updateParallax();
            rafScheduled = false;
          });
        };

        /* ---------------------- TILT (mouse-follow 3D) ---------------------- */
        const mountTilt = () => {
          if (prefersReduced) return;
          /* Only on devices with fine pointer (no touch/tablet) */
          if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;

          document.querySelectorAll("[data-tilt]").forEach((el) => {
            if (el.__tiltMounted) return;
            el.__tiltMounted = true;

            const maxAngle = parseFloat(el.dataset.tiltMax || "6");
            const onMove = (e) => {
              const rect = el.getBoundingClientRect();
              const x = (e.clientX - rect.left) / rect.width - 0.5;
              const y = (e.clientY - rect.top) / rect.height - 0.5;
              /* Flip Y so cursor-up = rotate-up (intuitive) */
              el.style.setProperty("--tilt-x", (y * -maxAngle).toFixed(2) + "deg");
              el.style.setProperty("--tilt-y", (x * maxAngle).toFixed(2) + "deg");
            };
            const onLeave = () => {
              el.style.setProperty("--tilt-x", "0deg");
              el.style.setProperty("--tilt-y", "0deg");
            };
            el.addEventListener("mousemove", onMove);
            el.addEventListener("mouseleave", onLeave);
          });
        };

        /* ---------------------- SPLIT REVEAL (word-by-word) ---------------------- */
        const mountSplitReveal = () => {
          document.querySelectorAll("[data-split-reveal]:not([data-split-done])").forEach((el) => {
            el.setAttribute("data-split-done", "true");

            /* Walk child nodes, wrap only text nodes (preserves <span class="text-vert">
               and other inner markup like line breaks). */
            const wrap = (node) => {
              if (node.nodeType === Node.TEXT_NODE) {
                const text = node.textContent || "";
                if (!text.trim()) return;
                const frag = document.createDocumentFragment();
                const words = text.split(/(\s+)/);
                words.forEach((w) => {
                  if (!w.trim()) {
                    frag.appendChild(document.createTextNode(w));
                    return;
                  }
                  const span = document.createElement("span");
                  span.className = "split-word";
                  span.textContent = w;
                  frag.appendChild(span);
                });
                node.parentNode.replaceChild(frag, node);
              } else if (node.nodeType === Node.ELEMENT_NODE) {
                /* Recurse into element children (e.g. <span class="text-vert">) */
                Array.from(node.childNodes).forEach(wrap);
              }
            };
            Array.from(el.childNodes).forEach(wrap);

            /* Apply stagger delays */
            const words = el.querySelectorAll(".split-word");
            words.forEach((w, i) => {
              w.style.setProperty("--split-delay", Math.min(i * 50, 800) + "ms");
            });

            /* Observe entry and reveal */
            if (prefersReduced) {
              words.forEach((w) => w.classList.add("is-revealed"));
              return;
            }
            if (!("IntersectionObserver" in window)) {
              words.forEach((w) => w.classList.add("is-revealed"));
              return;
            }
            const io = new IntersectionObserver(
              (entries) => {
                entries.forEach((entry) => {
                  if (entry.isIntersecting) {
                    words.forEach((w) => w.classList.add("is-revealed"));
                    io.unobserve(entry.target);
                  }
                });
              },
              { threshold: 0.2 }
            );
            io.observe(el);
          });
        };

        /* ---------------------- MOUNT + CLEANUP ---------------------- */
        const mount = () => {
          collectParallax();
          mountTilt();
          mountSplitReveal();
          onScrollFrame(); /* initial paint */
        };

        window.addEventListener("scroll", onScrollFrame, { passive: true });
        window.addEventListener("resize", onScrollFrame, { passive: true });
        document.addEventListener("astro:page-load", mount);

        if (document.readyState !== "loading") mount();
        else document.addEventListener("DOMContentLoaded", mount);
      })();
    </script>
  </body>
</html>
